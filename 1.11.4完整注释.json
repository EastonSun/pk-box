{
  // ============================================
  // 全局日志配置
  // ============================================
  "log": { 
    "level": "info",       // 日志级别：info 会记录一般信息、警告和错误，适合日常使用。可选 trace/debug/info/warn/error/fatal/panic
    "timestamp": true      // 日志是否带时间戳，方便排查问题时间线
  },

  // ============================================
  // DNS 解析配置 (核心优化点)
  // ============================================
  "dns": {
    "servers": [
      {
        "tag": "dns-resolver",         // 基础解析器，用于解析 DoH 服务器的域名
        "address": "223.5.5.5",        // 阿里云公共 DNS，国内使用速度快
        "detour": "direct"             // 强制走 direct 出站，不走代理
        // 疑惑：这里为什么不用加密 DNS？
        // 回答：这是"解析器的解析器"，负责解析下面 dns-direct/dns-proxy 中的域名地址。
        //       比如要连接 https://dns.alidns.com，得先知道 dns.alidns.com 的 IP 是什么，
        //       这个任务就由 dns-resolver 用标准的 UDP 53 端口去完成。因为它要走 direct，
        //       用国内明文的 223.5.5.5 反而最稳定、延迟最低。
      },
      {
        "tag": "dns-direct",           // 国内域名解析
        "address": "https://dns.alidns.com/dns-query",  // 阿里云 DoH，加密传输，防止 DNS 污染
        "address_resolver": "dns-resolver",  // 依赖上面那个服务器来解析 dns.alidns.com 的 IP
        "detour": "direct"             // 解析出来的流量走 direct 出站
      },
      {
        "tag": "dns-proxy",            // 国外域名解析
        "address": "https://1.1.1.1/dns-query",  // Cloudflare DoH，国际知名，隐私保护好
        "address_resolver": "dns-resolver",  // 同样依赖 dns-resolver 来解析 1.1.1.1 的 IP
        "detour": "proxy"              // 解析流量走代理，确保在国内能稳定连上 Cloudflare
      },
      {
        "tag": "dns-block",            // 广告拦截专用服务器
        "address": "rcode://success"   // 直接返回解析成功但给一个空结果 (0.0.0.0)，实现广告屏蔽
      }
    ],
    "rules": [
      {
        "rule_set": ["geosite-category-ads-all"],  // 匹配广告域名规则集
        "server": "dns-block",                     // 用 dns-block 拦截
        "disable_cache": true                      // 不缓存拦截结果，每次都要查，确保广告不遗漏
        // 疑惑：为什么广告拦截要禁用缓存？
        // 回答：广告域名可能随时变化，且部分应用会尝试轮询不同的广告域名。
        //       缓存了拦截结果后，如果规则集更新了某个域名不再拦截，你可能因为缓存而依然被拦。
        //       当然这里禁止缓存对性能影响极小，因为 dns-block 本身返回就极快。
      },
      {
        "domain_suffix": ["raw.githubusercontent.com"],  // GitHub 原始文件域名
        "server": "dns-direct"                           // 用国内 DNS 解析
        // 说明：raw.githubusercontent.com 虽在国外，但国内 DNS 也能解析出 IP，
        //       且后续路由规则里已经让它走 direct，所以 DNS 也用 direct 保持一致。
      },
      {
        "domain_suffix": [".cn"],   // 所有 .cn 结尾的域名
        "server": "dns-direct"      // 都用国内 DNS 解析，速度更快
      },
      {
        "rule_set": "geosite-cn",   // 规则集判定为国内域名的
        "server": "dns-direct"      // 也用国内 DNS 解析
      },
      {
        "rule_set": ["geosite-geolocation-!cn"],  // 规则集判定为非中国地区的域名
        "server": "dns-proxy"                     // 走代理 DNS 解析，防止污染，获取真实/最优 IP
        // 说明：为什么国外域名不用 direct 的 DNS？
        // 回答：国内 DNS 解析国外域名时，可能被投毒返回错误 IP，或被 CDN 导向国内节点速度慢。
        //       走代理用 Cloudflare DoH 能拿到最纯净、最适合代理访问的 IP。
      }
    ],
    "final": "dns-proxy",           // 兜底策略：没命中任何规则的域名，走代理 DNS 解析
    "independent_cache": true       // 独立缓存，DNS 缓存与规则各自独立，提高命中率
    // 疑惑：这里的 final 为什么是 dns-proxy 而不是 dns-direct？
    // 回答：这是一种"白名单"思想。国内已知的域名 (geosite-cn, .cn) 明确走 direct，
    //       除此之外的大量未知域名，默认认为是国外或需要代理才能访问的，走 proxy 更安全。
    //       如果你主要访问国内网站，这么设置反而不合理，改 direct 可能更快。
  },

  // ============================================
  // 网络时间同步
  // ============================================
  "ntp": {
    "enabled": true,            // 启用 NTP 时间同步
    "interval": "30m",         // 每 30 分钟同步一次
    "server": "ntp.aliyun.com", // 阿里云 NTP 服务器，国内延迟极低
    "server_port": 123          // NTP 标准端口
    // 说明：TLS 握手、证书校验都依赖准确的时间，尤其是代理的 VLESS+TLS 节点，
    //       时间偏差过大会导致握手失败。TUN 模式下系统时间可能不准，开启 NTP 很必要。
  },

  // ============================================
  // 入站配置 (流量入口)
  // ============================================
  "inbounds": [
    {
      "type": "mixed",           // 混合入站，同时提供 HTTP 代理和 SOCKS5 代理
      "tag": "mixed-in",
      "listen": "127.0.0.1",      // 仅监听本机，防止局域网内其他设备连入 (安全性)
      "listen_port": 7890,        // 经典端口，大部分软件默认代理端口
      "set_system_proxy": false   // 不自动修改系统代理，让用户手动控制
      // 说明：混合入站适合给浏览器、部分应用设置代理用，127.0.0.1 限制仅本机访问。
    },
    {
      "type": "tun",             // TUN 模式，虚拟网卡接管系统所有流量
      "tag": "tun-in",
      "mtu": 1500,               // 最大传输单元，以太网标准值
      "address": ["172.19.0.1/30", "fdfe:dcba:9876::1/126"],  // TUN 网卡的 IPv4/IPv6 地址
      "auto_route": true,        // 自动设置系统路由，让所有流量都走 TUN
      "strict_route": true,      // 严格路由，防止路由泄露
      "stack": "gvisor",         // 使用 gvisor 网络栈，用户态 TCP/IP 实现
                                 // 优点：不依赖系统内核，跨平台一致性好；缺点：性能略低于 system 栈
      "endpoint_independent_nat": true  // 端点无关 NAT，类似 Full Cone NAT
                                        // 对 P2P、游戏联机有帮助，NAT 类型更优
      // 说明：TUN 入站是实现"透明代理"的关键，无需给每个应用设代理，
      //       所有网络请求都被虚拟网卡捕获，交给 sing-box 路由。
    }
  ],

  // ============================================
  // 出站配置 (流量出口)
  // ============================================
  "outbounds": [
    {
      "type": "direct",   // 直连出站，不经过任何代理
      "tag": "direct"
    },
    {
      "type": "selector",  // 手动选择器，可在面板上手动切节点
      "tag": "proxy",
      "outbounds": [
        "auto",               // 自动测速选最快的
        "🚀 CF-优选-Visa",   // 手动选 Visa 节点
        "🚀 CF-优选-DO"      // 手动选 DO (DigitalOcean?) 节点
      ],
      "default": "auto"       // 默认使用自动测速
      // 说明：selector 是给用户在手动画板里切换的，灵活度最高。
      //       设置 default 为 auto，在不手动干预时自动选优。
    },
    {
      "type": "urltest",   // 自动测速出站，定期测速选最快节点
      "tag": "auto",
      "outbounds": [
        "🚀 CF-优选-Visa",
        "🚀 CF-优选-DO"
      ],
      "url": "https://www.gstatic.com/generate_204",  // 测速用 URL，Google 的 204 页面
      "interval": "3m",      // 每 3 分钟测一次
      "tolerance": 50        // 容忍度 50ms，新节点要比当前节点快 50ms 以上才切换
      // 说明：tolerance 防止频繁切换。比如当前 300ms，新节点 270ms，只快了 30ms，
      //       没超过 50ms 容忍度就不切，避免网络抖动引起的乒乓效应。
    },
    {
      "tag": "🚀 CF-优选-Visa",  // 节点标签，用 emoji 方便面板显示
      "server": "CF优选域名IP",   // Cloudflare 优选出的高速 IP
      "server_port": 443,
      "type": "vless",            // VLESS 协议，没有内置加密，依赖 TLS 加密
      "uuid": "uuid",            // 用户身份标识 (请替换为真实 UUID)
      "tls": {
        "enabled": true,
        "server_name": "反向域名",  // SNI，填你套 CDN 的域名
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"  // 模拟 Chrome 浏览器的 TLS 指纹
          // 说明：uTLS 伪装 TLS 握手特征，避免被识别出是代理工具。
          //       fingerprint 设为 chrome 伪装成浏览器流量。
        },
        "insecure": false  // 严格校验 TLS 证书，false 是安全做法
      },
      "transport": {
        "type": "ws",             // WebSocket 传输，伪装成普通网页流量
        "path": "路径",           // WebSocket 路径 (请替换为实际路径)
        "headers": {
          "Host": "反向域名"      // 头部 Host，与 server_name 一致
        }
      }
      // 疑惑：为什么 server 填的是 IP，server_name 却填域名？
      // 回答：这就是 Cloudflare 优选 IP 的精髓。
      //       server 填优选出的高速 IP，直连那个 IP 的 443 端口；
      //       server_name 填你的真实域名，用于 TLS SNI 握手和 CF 回源识别。
      //       CF 边缘节点看到 SNI 是你的域名，就知道该回源到哪个源站。
    },
    {
      "tag": "🚀 CF-优选-DO",     // 另一个节点，可能是不同地区或不同优选 IP
      "server": "CF优选域名IP",   // 同上结构
      "server_port": 443,
      "type": "vless",
      "uuid": "uuid",
      "tls": {
        "enabled": true,
        "server_name": "反向域名",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "insecure": false
      },
      "transport": {
        "type": "ws",
        "path": "路径",
        "headers": {
          "Host": "反向域名"
        }
      }
      // 说明：两个节点可能优选了不同的 IP (如一个亚洲优化 IP，一个欧美 IP)，
      //       通过 urltest 自动选最快的用，提高可用性。
    }
    // 注意：这里 outbounds 数组最后一个元素后面多了一个逗号，JSON 规范不允许，
    //       实际使用时要删除。
  ],

  // ============================================
  // 路由配置 (核心优化点)
  // ============================================
  "route": {
    "rule_set": [
      // ---- 远程规则集，定期自动更新 ----
      {
        "type": "remote",
        "tag": "geoip-cn",           // 中国 IP 地址库
        "format": "binary",          // .srs 二进制格式，sing-box 专用，加载快、占用小
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-cn.srs",
        "download_detour": "direct", // 下载规则集时走 direct 出站 (直连 GitHub)
        "update_interval": "24h"     // 每 24 小时更新一次
      },
      {
        "type": "remote",
        "tag": "geosite-cn",         // 中国域名规则集 (包含国内各种网站、APP 域名)
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-cn.srs",
        "download_detour": "direct",
        "update_interval": "24h"
      },
      {
        "type": "remote",
        "tag": "geosite-geolocation-!cn",  // 非中国地区域名规则集 (国外常用网站)
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-!cn.srs",
        "download_detour": "direct",
        "update_interval": "24h"
      },
      {
        "type": "remote",
        "tag": "geosite-category-ads-all",  // 广告域名规则集
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ads-all.srs",
        "download_detour": "direct",
        "update_interval": "24h"
      }
    ],
    "rules": [
      {
        "action": "sniff"  // 域名嗅探，从流量中检测真实域名，用于更精准的路由
        // 说明：有些流量 (如 HTTPS) 的域名在请求里是加密的，但 TLS SNI 或 HTTP Host
        //       头部可以暴露域名。sniff 就是去提取这些信息，方便后续域名规则匹配。
        //       放在第一条确保所有入站流量都进行嗅探。
      },
      {
        "protocol": "dns",          // 匹配 DNS 协议流量
        "action": "hijack-dns"      // 劫持 DNS 请求，转发到 sing-box 内置 DNS 模块
        // 说明：TUN 模式下，应用的 DNS 请求 (如发往 8.8.8.8:53) 会被捕获到这里，
        //       然后 hijack-dns 动作把它转交给上面 dns 部分配置的服务器处理。
        //       这样做的好处：所有 DNS 都走加密 DoH，且遵照分流规则，防止 DNS 泄露。
      },
      {
        "ip_is_private": true,       // 匹配私有 IP 地址 (192.168.x.x, 10.x.x.x, 172.16-31.x.x)
        "outbound": "direct"         // 局域网、内网流量直连，不能走代理
        // 说明：访问路由器管理页面、NAS、打印机等内网设备，必须直连。
        //       放在靠前位置避免被后续规则误分流到代理。
      },
      {
        "domain_suffix": ["raw.githubusercontent.com"],  // GitHub 原始文件
        "outbound": "direct"                             // 直连
        // 说明：这个域名用于下载规则集、面板等资源，走直连保证能稳定下载。
        //       虽然它在美国，但国内访问通常还行，且下载流量不大。
      },
      {
        "rule_set": ["geosite-category-ads-all"],  // 匹配广告域名
        "action": "reject"                         // 直接拒绝连接
        // 说明：路由层面的 reject 与 DNS 层面的 block 配合使用。
        //       DNS 返回空结果，路由 reject 阻断连接，双重保障广告过滤。
      },
      {
        "rule_set": ["geosite-cn", "geoip-cn"],  // 匹配国内域名或国内 IP
        "outbound": "direct"                     // 直连
        // 说明：国内网站直连速度最快，不消耗代理流量。
        //       geosite-cn 负责域名匹配，geoip-cn 负责 IP 匹配，互补。
      },
      {
        "domain_suffix": [".cn"],  // .cn 后缀域名
        "outbound": "direct"       // 直连
        // 说明：.cn 域名 99.9% 在国内，直接直连。
        //       这条与 geosite-cn 有重叠但作为显式声明兜底。
      },
      {
        "rule_set": "geosite-geolocation-!cn",  // 非中国地区域名
        "outbound": "proxy"                     // 走代理
        // 说明：国外网站走代理，保证能访问和速度。
      }
    ],
    "final": "proxy",                // 兜底策略：未匹配任何规则的流量，走代理
    "auto_detect_interface": true    // 自动检测网络接口，多网卡时可正常路由
    // 疑惑：final 为 proxy 意味着所有未知流量都走代理，会不会浪费？
    // 回答：这是一种"黑名单"思想的补充。国内常见的都已经匹配直连了，
    //       剩下的未知流量，大概率是需要代理的 (国外小众网站、被墙的等)。
    //       如果你代理流量有限且愿意冒风险，可以改为 direct，让未知流量直连，
    //       但可能会漏掉一些需要代理才能访问的网站。
  },

  // ============================================
  // 实验性功能
  // ============================================
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "sing-box-cache.db",  // 缓存数据库文件路径
      "store_rdrc": true            // 存储 RDRC (DNS 响应)
      // 说明：缓存 DNS 结果和规则匹配结果，重启后不用重新解析、下载。
      //       store_rdrc 进一步缓存 DNS 响应，加速后续相同域名解析。
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",  // Clash API 监听地址
      "external_ui": "ui",                      // 面板静态文件存放的本地路径
      "external_ui_download_url": "https://github.com/MetaCubeX/metacubexd/archive/refs/heads/gh-pages.zip",  // 自动下载面板的 URL
      "external_ui_download_detour": "direct"   // 下载面板时走 direct
      // 说明：启用 Clash API 意味着可以用 MetaCubeXD 等面板来管理 sing-box，
      //       查看连接、切换节点、测速等。127.0.0.1:9090 仅本机访问，安全。
      //       面板文件在 ui 目录下，如果不存在会自动下载。
    }
  }

  // ============================================
  // 总结
  // ============================================
  // 这是一份典型的"国内直连、国外代理、广告拦截"的分流配置。
  // 优化点：
  // 1. DNS 分流解析：国内用阿里 DoH，国外用 Cloudflare DoH 走代理，防污染同时保证速度
  // 2. 规则集自动更新：geoip/geosite 每 24 小时更新，适配网络环境变化
  // 3. CF 优选 IP + 自动测速：两个优选节点自动切换，提高代理可用性
  // 4. TUN 透明代理 + DNS 劫持：全系统覆盖，应用无需设置代理
  // 5. uTLS 指纹伪装 + WebSocket 传输：增强隐匿性
  //
  // 注意事项：
  // - 出站配置末尾有 JSON 语法错误 (多余逗号)，使用前需修正
  // - uuid、server、路径、反向域名 等占位符需要替换为真实信息
  // - final 策略可根据个人需求在 proxy/direct 之间选择
}
