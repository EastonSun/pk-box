        // Firebase Cloud Messaging：App 推送通知的基础服务
        // 不走代理的话，Android 上很多 App 收不到通知
        "download_detour": "DIRECT",
        "update_interval": "48h0m0s"
      },
      {
        "type": "remote",
        "tag": "google-sns",
        "url": "https://cdn.jsdelivr.net/gh/senshinya/singbox_ruleset@main/rule/Google/Google.srs",
        "download_detour": "DIRECT",
        "update_interval": "48h0m0s"
      },
      {
        "type": "remote",
        "tag": "android-sys",
        "url": "https://cdn.jsdelivr.net/gh/senshinya/singbox_ruleset@main/rule/Android/Android.srs",
        // Android 系统级服务（GMS/SafetyNet等），确保系统服务可用
        "download_detour": "DIRECT",
        "update_interval": "48h0m0s"
      },

      // ── 反欺诈 ──
      {
        "type": "remote",
        "tag": "anti_fraud",
        "url": "https://cdn.jsdelivr.net/gh/hwsaya/nothing@main/rules/FuckFZ.json",
        // 反欺诈/反钓鱼网站规则
        // 【注意】这个规则集格式是 .json 不是 .srs，确认 sing-box 版本支持
        "download_detour": "DIRECT",
        "update_interval": "48h0m0s"
      },

      // ── FakeIP 过滤 ──
      {
        "type": "remote",
        "tag": "fakeip-filter",
        "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/fakeip-filter.srs",
        // 包含不适合 FakeIP 的域名（邮件/推送/某些 API 等）
        // 这些域名需要真实 IP 才能正常工作
        "download_detour": "DIRECT",
        "update_interval": "48h0m0s"
      },

      // ── 额外广告 ──
      {
        "type": "remote",
        "tag": "ads-extra",
        "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/ads.srs",
        "download_detour": "DIRECT",
        "update_interval": "48h0m0s"
      }
    ],

    "final": "PROXY",
    // 没有命中任何路由规则的流量，默认走代理
    // 宁可多走代理，也不轻易直连（安全优先策略）

    "find_process": true,
    // 查找发起连接的进程名称，用于进程级规则匹配（package_name等）
    // 在 Android 上是实现按 App 分流的必要条件

    "auto_detect_interface": true,
    // 自动检测出口网络接口（WiFi/以太网/移动数据）
    // sing-box 会自动选择正确的网络接口，无需手动配置

    "default_domain_resolver": "alidns_doh"
    // 路由层面默认的域名解析器
    // 当路由规则需要解析域名时（如 action: resolve），使用这个 DNS
  },

  // ══════════════════════════════════════════════════════════
  // 【实验性功能 Experimental】
  // ══════════════════════════════════════════════════════════
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      // 缓存文件路径，相对于 sing-box 工作目录
      // 存储 DNS 缓存、FakeIP 映射、路由缓存等，加速重启后的响应

      "cache_id": "cinchov",
      // 缓存隔离 ID：不同 ID 的配置使用不同的缓存空间
      // 防止多个 sing-box 实例共享缓存造成混乱
      // 【疑惑】这个值有什么规律？
      // 【回答】任意字符串，作者自定义的，可以改成任何你喜欢的名字

      "store_fakeip": true,
      // 持久化 FakeIP 映射：重启后不会丢失 FakeIP 和域名的对应关系
      // 防止重启后出现 IP 映射错乱导致部分网站无法访问

      "store_rdrc": true,
      // RDRC = Rejected DNS Response Cache（拒绝的 DNS 响应缓存）
      // 记录被拒绝的 DNS 请求，避免重复触发拒绝逻辑

      "rdrc_timeout": "168h0m0s"
      // RDRC 缓存过期时间：168 小时 = 7 天
      // 一周后清理，防止缓存无限增长
    },

    "clash_api": {
      // Clash API 兼容接口：提供 Web 控制面板（Dashboard）
      "external_controller": "127.0.0.1:9090",
      // 控制面板监听地址和端口
      // 只监听本地，安全；端口 9090 是 Clash 传统端口

      "external_ui": "ui",
      // 前端 UI 文件存储目录名（相对于工作目录）

      "external_ui_download_url": "https://github.com/MetaCubeX/metacubexd/archive/gh-pages.zip",
      // 自动下载 MetaCubeXD 面板（Clash.Meta 的现代化 Web UI）
      // 提供节点管理、流量统计、规则查看等功能

      "external_ui_download_detour": "PROXY",
      // 下载 UI 时走代理（因为 GitHub 在国内不稳定）

      "secret": "kSDuU2WHyf72taGMdDS0ib6klwFVF5QIM4HGhS5f4Jw=",
      // 访问控制面板的密钥（Bearer Token）
      // 【安全提示】这是你配置文件中的真实密钥，建议定期更换
      //             访问 http://127.0.0.1:9090/ui 时需要填写此密钥

      "default_mode": "rule"
      // 默认分流模式：rule（按规则分流）
      // 可选：direct（全直连）/ global（全代理）/ rule（按规则）
    }
  }
}

// ============================================================
// 【总结：整体流量走向示意图】
//
//  用户请求 example.com
//       │
//       ▼
//  [DNS 解析]
//       │
//       ├─ .local/.lan/路由器域名 → local DNS
//       ├─ .cn/国内域名/cnip规则集 → alidns_doh → 真实IP
//       ├─ 广告/追踪域名 → REJECT（返回NXDOMAIN）
//       └─ 代理域名（Google/TikTok等）→ fakeip → 198.18.x.x
//
//       ▼
//  [路由匹配]（按规则顺序）
//       │
//       ├─ 端口53/DNS协议 → hijack-dns（内部处理）
//       ├─ sniff → 提取域名（TLS SNI / HTTP Host）
//       ├─ 私有IP → DIRECT
//       ├─ 198.18.0.0/15（FakeIP）→ PROXY
//       ├─ 广告规则集 → REJECT
//       ├─ 中国主流网站关键字/后缀 → CN（直连）
//       ├─ Google/YouTube/AI等规则集 → PROXY
//       ├─ resolve → 获取真实IP
//       ├─ 中国IP段/规则集 → CN（直连）
//       ├─ Android App包名列表 → PROXY
//       └─ 其他（final）→ PROXY（默认代理）
//
//       ▼
//  [出站]
//       ├─ PROXY → AUTO（自动最快节点）/ 手动选择节点
//       ├─ CN → DIRECT（直连）
//       └─ DIRECT → 直接连接
// ============================================================
