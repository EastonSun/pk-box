      "external_ui_download_url": "https://cdn.jsdelivr.net/gh/MetaCubeX/metacubexd@gh-pages/metacubexd.zip",
      "external_ui_download_detour": "PROXY",    // 通过代理下载面板文件
      "secret": "kSDuU2WHyf72taGMdDS0ib6klwFVF5QIM4HGhS5f4Jw=",
      // API 密钥（SHA-256 哈希），访问面板时需要提供
      // ★ 建议修改为你自己的密钥，或生成新的随机字符串
      // 生成方式：echo -n "你的密码" | sha256sum
      "default_mode": "rule"                     // 默认模式：rule（规则模式）
                                                 // 可选：direct（全局直连）、global（全局代理）
    },

    // ---- 7.2 缓存文件（三个版本完全相同） ----
    "cache_file": {
      "enabled": true,
      "path": "cache.db",                        // 缓存数据库文件路径
      "cache_id": "cinchov",                     // 缓存标识，用于区分不同用户/设备
      "store_fakeip": true                       // 持久化存储 FakeIP 映射
      // 即使 sing-box 重启，FakeIP 映射仍然保留
      // 客户端缓存中的 FakeIP 不会失效，避免重启后大量连接断开
      // 生效前提：DNS 中使用了 fakeip 服务器，且路由中有对应 ip_cidr 规则
    }
  }

  // ============================================
  // 附录：使用建议与常见问题
  // ============================================
  // ★ 必须修改的占位符（共 8 处）：
  //   1. "节点域名" → 你的实际节点域名（DNS 规则、出站节点配置中）
  //   2. "CF优选域名IP" → 你测出的 Cloudflare 优选 IP（两个节点配置中）
  //   3. "uuid" → 你的 VLESS UUID（两个节点配置中）
  //   4. "/路径" → 你的 WebSocket 路径（两个节点配置中）
  //
  // ★ 推荐修改：
  //   1. secret → 生成你自己的 API 密钥
  //   2. cache_id → 改成唯一标识（随便字符串）
  //
  // ★ 版本选择建议：
  //   - 新手：推荐 1.13.10-11 版本，规则合并更整洁
  //   - 稳定优先：推荐 1.13.8 或 1.13.9，改动较少
  //   - 1.13.10-11 的 final DNS 改成 ggdns_doh，如果觉得国内解析慢，可改回 alidns_udp
  //
  // ★ 调优建议：
  //   1. log.level → 日常使用改为 "info" 或 "warn"
  //   2. dns.cache_capacity → 可根据设备内存调整（内存小则减小）
  //   3. urltest.interval → 如果节点稳定，可改为 30m 减少探测流量
  //   4. 如果不需要蜂窝直连，删除 route.rules 中的 network_type: cellular 规则
}
