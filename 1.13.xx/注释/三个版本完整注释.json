        "tag": "cnip",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/cnip.srs",
        "download_detour": "PROXY",
        "update_interval": "48h"
        // 中国 IP 段（APNIC 分配的所有中国 IP）
        // 比 GeoIP 数据库更新频率更高
      }
    ],

    // ---- 6.4 路由最终策略 ----
    "final": "PROXY",
    // 所有未命中规则的流量默认走代理
    // 这是"白名单"模式：已知国内走直连，其他全代理
    // 好处：不会漏掉需要代理的网站
    // 坏处：可能把一些国内小众网站走了代理（浪费流量/降低速度）
    // 三个版本完全相同

    "auto_detect_interface": true
    // 自动检测网络出口接口
    // 当系统网络变化时（如切换 Wi-Fi/有线），自动重新检测
  },

