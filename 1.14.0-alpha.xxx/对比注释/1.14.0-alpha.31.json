      {
        "ip_cidr": "198.18.0.0/15",  // IPv4 fakeip段
        "outbound": "PROXY"
      },
      {
        "ip_cidr": "fc00::/18",      // IPv6 fakeip段
        "outbound": "PROXY"
      },

      // ======================================================================
      // 规则15: NTP和ICMP协议 -> 直连
      // 时间同步和网络诊断流量不应该走代理
      // ======================================================================
      {
        "protocol": [
          "ntp",    // 网络时间协议
          "icmp"    // 网际控制报文协议 (ping)
