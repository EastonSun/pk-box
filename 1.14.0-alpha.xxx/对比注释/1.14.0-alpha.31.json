    // ------------------------------------------------------------------------
    "final": "Final",

    // ------------------------------------------------------------------------
    // 自动检测网络接口
    // 自动选择可用的网络接口
    // ------------------------------------------------------------------------
    "auto_detect_interface": true,

    // ------------------------------------------------------------------------
    // 默认域名解析器
    // 当没有特别指定时，使用阿里DNS解析域名
    // ------------------------------------------------------------------------
    "default_domain_resolver": "alidns-quic"
  },

  // ==========================================================================
  // 服务配置
  // 提供额外的API服务
  // ==========================================================================
  "services": [
    {
      "type": "api",           // API服务
      "tag": "api",
      "listen": "127.0.0.1",   // 监听本地地址
      "listen_port": 9091,     // API端口
      "access_control_allow_private_network": true  // 允许私有网络访问
    }
  ],

  // ==========================================================================
  // 实验性功能
  // 仍在开发中但已可用的功能
  // ==========================================================================
  "experimental": {
    // ------------------------------------------------------------------------
    // 缓存文件
    // 持久化DNS缓存和FakeIP映射，重启后不丢失
    // ------------------------------------------------------------------------
    "cache_file": {
      "enabled": true,
      "path": "cache.db",      // 缓存数据库文件
      "store_fakeip": true     // 存储FakeIP映射关系
    },
    // ------------------------------------------------------------------------
    // Clash API兼容模式
    // 提供与Clash兼容的REST API，支持metacubexd等面板
    // ------------------------------------------------------------------------
    "clash_api": {
      "external_controller": "127.0.0.1:9090",  // API监听地址
      "external_ui": "ui",                       // 面板UI目录
      "external_ui_download_url": "https://github.com/MetaCubeX/metacubexd/archive/gh-pages.zip", // 面板下载地址
      "external_ui_download_detour": "PROXY",    // 通过代理下载面板
      "default_mode": "rule",                    // 默认模式: rule(规则)/global(全局)/direct(直连)
      "access_control_allow_private_network": true  // 允许私有网络访问API
    }
  }
}

// ============================================================================
// 总结与说明
// ============================================================================
// 
// 【配置文件整体架构】
// 这是一个Sing-Box代理客户端的完整配置文件，主要实现以下功能:
// 1. TUN模式透明代理 - 接管系统所有流量
// 2. DNS分流 - 根据域名返回真实IP或FakeIP
// 3. 路由规则 - 决定哪些流量走代理，哪些直连，哪些拒绝
// 4. 广告/跟踪域名过滤
// 5. 多协议入站支持 (HTTP/SOCKS5/Mixed/Redirect)
//
// 【核心工作流程】
// 1. 客户端发起连接请求 -> TUN网卡捕获流量
// 2. 如果是DNS请求 -> 根据DNS规则选择上游DNS
// 3. 如果是普通流量 -> 经过路由规则匹配
//    - 海外域名 -> DNS返回FakeIP (198.18.x.x) -> 命中FakeIP段规则 -> 走PROXY出站
//    - 国内域名 -> DNS返回真实IP -> 直连或放行
//    - 广告域名 -> DNS返回空响应或拒绝连接
// 4. 流量通过出站发出 (代理节点/直连/拒绝)
//
// 【关键技术点】
// 1. FakeIP技术: 为被代理域名返回虚假IP，代理工具根据虚假IP反查原始域名进行代理
// 2. 规则集: 远程下载预定义域名列表，避免手动维护大量规则
// 3. DNS乐观缓存: 过期后先返回缓存再异步更新，提高响应速度
// 4. UR
