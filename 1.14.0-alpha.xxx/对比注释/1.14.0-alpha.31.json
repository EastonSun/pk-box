          "facebook.com",      // 脸书
          "fbcdn.net",         // 脸书CDN
          "amazon.com",        // 亚马逊
          "microsoft.com",     // 微软
          "paypal.com"         // 贝宝
        ],
        "outbound": "PROXY"
      },

      // ======================================================================
      // 规则12: 更多规则集 -> 走代理
      // ======================================================================
      {
        "rule_set": [
          "Proxy",      // 非中国内地域名
          "gfw",        // 防火长城列表
          "ai",         // AI服务
          "games",      // 游戏
          "GlobalMedia", // 全球媒体
          "proxy"       // 自定义代理列表
        ],
        "outbound": "PROXY"
      },

      // ======================================================================
      // 规则13: Clash模式Global -> 走代理
      // 兼容Clash API的全局模式
      // ======================================================================
      {
        "clash_mode": "Global",
        "outbound": "PROXY"
      },

      // ======================================================================
      // 规则14: FakeIP地址段 -> 走代理
      // 在DNS阶段返回fakeip的域名，其流量会落在这些IP段上
