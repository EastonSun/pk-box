          "ipleak.net",         // IP泄漏测试
          "dnsleaktest.com",    // DNS泄漏测试
          "whoer.net",          // 综合匿名测试
          "whatleaks.com",      // 泄漏测试
          "ip.sb",              // IP查询
          "ipinfo.io",          // IP信息
          "ifconfig.me",        // 连接信息
          "ip-api.com"          // IP地理位置
        ],
        "outbound": "PROXY"
      },

      // ======================================================================
      // 规则9: Google全家桶域名 -> 走代理
      // ======================================================================
      {
        "domain_suffix": [
          "play.google.com",
          "play.googleapis.com",
          "android.clients.google.com",
          "android.googleapis.com",
          "dl.google.com",
          "dl.l.google.com",
          "gvt1.com",
          "gvt2.com",
          "gvt3.com",
          "services.googleapis.com",
