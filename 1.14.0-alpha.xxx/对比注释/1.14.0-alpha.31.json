          "app-measurement.com",
          "firebaselogging.googleapis.com",
          "firebaselogging-pa.googleapis.com"
        ],
        "outbound": "PROXY"
      },

      // ======================================================================
      // 规则10: 规则集中的海外服务 -> 走代理
      // ======================================================================
      {
        "rule_set": [
          "geosite-google",
          "geosite-youtube",
          "instagram",
          "telegram",
          "telegram_ip",
          "Google",
          "fcm",               // Firebase Cloud Messaging
