// ============================================================================
// Sing-Box 配置文件完整注释
// 版本: 1.0
// 用途: 代理客户端配置，支持TUN模式、DNS分流、路由规则等
// ============================================================================

{
  // ==========================================================================
  // 日志配置模块
  // 控制程序运行时的日志输出级别和格式
  // ==========================================================================
  "log": {
    // 日志级别: trace(最详细) > debug > info > warn > error > fatal > panic
    // trace级别会记录所有DNS查询、连接建立等详细信息，适合调试
    "level": "trace",
    // 是否在每条日志前添加时间戳，便于问题排查
    "timestamp": true
  },

  // ==========================================================================
  // DNS配置模块
  // 负责域名解析、分流、缓存等，是整个代理的核心组件
  // ==========================================================================
  "dns": {
    // ------------------------------------------------------------------------
    // DNS服务器列表
    // 定义多个DNS服务器，后续规则会引用这些服务器进行域名解析
    // ------------------------------------------------------------------------
    "servers": [
      // ======================================================================
      // 服务器1: Hosts文件类型DNS
      // 功能: 内置静态域名映射，相当于系统hosts文件
      // 优先级最高，用于强制指定某些域名的IP地址
      // ======================================================================
      {
        // 服务器类型: hosts - 静态映射
        "type": "hosts",
        // 标签，供其他模块引用 (如domain_resolver: "hosts_fix")
        "tag": "hosts_fix",
        // 预定义的域名-IP映射表
        "predefined": {
          // 阿里公共DNS服务器的域名到IP映射
          "dns.alidns.com": [
            "223.5.5.5",
            "223.6.6.6"
          ],
          // AdGuard DNS服务器
          "dns.adguard.com": [
            "94.140.14.15",
            "94.140.15.16"
          ],
          // 腾讯公共DNS (DNSPod)
          "doh.pub": [
            "1.12.12.21",
            "120.53.53.53"
          ],
          // Google DNS
          "dns.google": [
            "8.8.8.8",
            "8.8.4.4"
          ],
          // Cloudflare DNS
          "cloudflare-dns.com": [
            "104.16.248.249",
            "104.16.249.249"
          ],
          // Cloudflare DNS别名
          "dns.cloudflare.com": [
            "104.16.248.249",
            "104.16.249.249"
          ],
          // Quad9 DNS (安全/隐私保护)
          "dns.quad9.net": [
            "9.9.9.9",
            "149.112.112.112"
          ],
          // Google推送服务域名，用于FCM消息推送
          "mtalk.google.com": [
            "142.250.107.188",
            "142.251.170.188",
            "108.177.125.188"
          ],
          // Google推送备用服务器
          "alt1-mtalk.google.com": "74.125.200.188"
        }
      },

      // ======================================================================
      // 服务器2: QUIC协议的DNS服务器
      // QUIC基于UDP，速度更快，抗丢包能力强
      // ======================================================================
      {
        // 类型: quic - 使用QUIC协议的DNS-over-QUIC
        "type": "quic",
        // 标签标识
        "tag": "alidns-quic",
        // 转发路径: DIRECT表示直连(不经过代理)
        "detour": "DIRECT",
        // 使用hosts_fix服务器来解析这个DNS服务器的域名 (避免循环依赖)
        "domain_resolver": "hosts_fix",
        // 目标服务器域名 (会通过hosts_fix解析为IP)
        "server": "dns.alidns.com"
      },

      // ======================================================================
      // 服务器3: DNS-over-HTTPS (腾讯DNSPod)
      // 加密DNS请求，防止中间人攻击和DNS劫持
      // ======================================================================
      {
        "type": "https",           // DOH协议
        "tag": "dnspub-doh",       // 标签: 公共DNS
        "detour": "DIRECT",        // 直接连接
        "domain_resolver": "hosts_fix",  // 先用hosts解析服务器域名
        "server": "doh.pub"        // 腾讯公共DNS域名
      },

      // ======================================================================
      // 服务器4: Google DNS over HTTPS
      // 注意: detour为PROXY，表示通过代理访问Google DNS
      // ======================================================================
      {
        "type": "https",
        "tag": "ggdns",            // Google DNS标签
        "detour": "PROXY",         // 关键: 通过代理访问 (因为Google DNS被墙)
        "domain_resolver": "hosts_fix",
        "server": "dns.google"     // dns.google.com
      },

      // ======================================================================
      // 服务器5: AdGuard DNS over QUIC
      // 自带广告过滤功能的DNS服务，通过代理访问
      // ======================================================================
      {
        "type": "quic",
        "tag": "adguard-dns",
        "detour": "PROXY",         // 通过代理访问 (AdGuard在海外)
        "domain_resolver": "hosts_fix",
        "server": "dns.adguard.com"
      },

      // ======================================================================
      // 服务器6: Quad9 DNS over HTTPS
      // 注重隐私保护和安全的DNS服务
      // ======================================================================
      {
        "type": "https",
        "tag": "quad9-doh",
        "detour": "PROXY",         // 通过代理访问
        "domain_resolver": "hosts_fix",
        "server": "dns.quad9.net"
      },

      // ======================================================================
      // 服务器7: FakeIP服务器
      // 用途: 为被代理的域名返回虚假IP地址(198.18.x.x)
      // 原理: 代理工具截获这些虚假IP的流量，然后根据原始域名进行代理转发
      // 优点: 减少DNS延迟，避免DNS污染，支持SNI分流
      // ======================================================================
      {
        "type": "fakeip",
        "tag": "fakeip",
        // IPv4虚假地址范围: 198.18.0.0/15 (约13万个IP)
        "inet4_range": "198.18.0.0/15",
        // IPv6虚假地址范围: fc00::/18 (ULA地址段)
        "inet6_range": "fc00::/18"
      }
    ],

    // ------------------------------------------------------------------------
    // DNS路由规则
    // 按照从上到下的顺序匹配，匹配到第一个规则后停止
    // ------------------------------------------------------------------------
    "rules": [
      // ======================================================================
      // 规则1: 游戏平台域名 -> 使用fakeip
      // 这些域名的DNS请求会返回虚假IP，用于后续代理
      // ======================================================================
      {
        // 匹配域名后缀列表 (只要域名以这些后缀结尾就匹配)
        "domain_suffix": [
          "steamcontent.com",   // Steam内容服务器
          "steamserver.net",    // Steam服务器
          "epicgames.com",      // Epic游戏平台
          "gog.com",            // GOG游戏平台
          "battle.net",         // 暴雪战网
          "blizzard.com",       // 暴雪娱乐
          "origin.com",         // EA Origin平台
          "ea.com",             // EA游戏
          "ubisoft.com",        // 育碧
          "rockstargames.com"   // R星游戏
        ],
        "server": "fakeip"       // 使用fakeip服务器
      },

      // ======================================================================
      // 规则2: Google Play下载相关域名 -> 使用Google DNS (ggdns)
      // 注意: 这里指定了query_type为A和AAAA，只拦截IPv4和IPv6记录
      // ======================================================================
      {
        // 只匹配A记录(IPv4地址)和AAAA记录(IPv6地址)
        "query_type": [
          "A",
          "AAAA"
        ],
        "domain_suffix": [
          "android.clients.google.com",    // Android客户端
          "dl.google.com",                 // Google下载服务器
          "dl.l.google.com",               // Google下载备用
          "play.google.com",               // Google Play商店
          "play.googleapis.com",           // Play API
          "play-fe.googleapis.com",        // Play前端
          "play-lh.googleusercontent.com", // Play图片资源
          "play-apps-features.googleusercontent.com", // Play应用特性
          "playstoregatewayadapter-pa.googleapis.com", // Play网关
          "prod-lt-playstoregatewayadapter-pa.googleapis.com", // Play生产环境
          "gvt1.com",                      // Google视频传输
          "gvt2.com",
          "gvt3.com"
        ],
        "server": "ggdns"        // 使用Google DNS (通过代理)
      },

      // ======================================================================
      // 规则3: 海外服务域名 -> 返回fakeip
      // 这个规则覆盖了Google全家桶、YouTube、Twitter、Facebook等
      // ======================================================================
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "domain_suffix": [
          "play.google.com",
          "play.googleapis.com",
          "android.clients.google.com",
          "android.googleapis.com",
          "dl.google.com",
          "dl.l.google.com",
          "gvt1.com",
          "gvt2.com",
          "gvt3.com",
          "services.googleapis.com",   // Google服务
          "googleapis.com",             // Google API
          "gstatic.com",                // Google静态资源
          "google.com",                 // Google搜索
          "google.com.hk",              // 香港Google
          "ggpht.com",                  // Google图片托管
          "googleusercontent.com",      // Google用户内容
          "youtube.com",                // YouTube
          "ytimg.com",                  // YouTube图片
          "googlevideo.com",            // Google视频
          "app-measurement.com",        // Google分析
          "firebaselogging.googleapis.com", // Firebase日志
          "firebaselogging-pa.googleapis.com",
          "twitter.com",                // 推特
          "twimg.com",                  // 推特图片
          "facebook.com",               // 脸书
          "fbcdn.net",                  // 脸书CDN
          "instagram.com",              // Instagram
          "cdninstagram.com"            // Instagram CDN
        ],
        "server": "fakeip"
      },

      // ======================================================================
      // 规则4: 规则集匹配 -> 返回fakeip
      // 使用预定义的规则集，更加高效和全面
      // ======================================================================
      {
        "rule_set": [
          "geosite-google",     // Google相关域名集合
          "geosite-youtube",    // YouTube域名集合
          "instagram",          // Instagram域名集合
          "telegram",           // Telegram域名集合
          "Proxy",              // 通用代理域名集合 (非中国大陆)
          "gfw",                // GFW列表域名
          "ai",                 // AI服务域名 (OpenAI, Anthropic等)
          "games",              // 游戏平台域名
          "GlobalMedia"         // 全球媒体服务 (Netflix, Spotify等)
        ],
        "server": "fakeip"
      },

      // ======================================================================
      // 规则5: Steam本地缓存域名 -> 使用阿里QUIC DNS
      // 用于局域网内Steam缓存服务器
      // ======================================================================
      {
        "domain_suffix": "lancache.steamcontent.com",
        "server": "alidns-quic"    // 使用阿里DNS (直连)
      },

      // ======================================================================
      // 规则6: 微软网络连通性测试域名 -> 使用阿里DNS
      // 这些域名用于检测网络是否连通，不需要代理
      // ======================================================================
      {
        "domain_suffix": [
          "msftncsi.com",        // Microsoft Network Connectivity Status Indicator
          "msftconnecttest.com"  // Microsoft连接测试
        ],
        "server": "alidns-quic"
      },

      // ======================================================================
      // 规则7: 私有网络域名 -> 使用DNSPod DOH
      // 私有域名如内网服务、局域网地址等
      // ======================================================================
      {
        "rule_set": "private",
        "server": "dnspub-doh"
      },

      // ======================================================================
      // 规则8: 中国内地域名 -> 使用DNSPod DOH
      // 这些域名应该返回真实IP，不需要fakeip
      // ======================================================================
      {
        "rule_set": "cn",
        "server": "dnspub-doh"
      },

      // ======================================================================
      // 规则9: .cn和.com.cn域名 -> 使用阿里QUIC DNS
      // 中国国家域名，直连解析
      // ======================================================================
      {
        "domain_suffix": [
          ".cn",
          ".com.cn"
        ],
        "server": "alidns-quic"
      },

      // ======================================================================
      // 规则10: Filter规则集 -> 使用阿里DNS
      // Filter包含应该直连的域名白名单
      // ======================================================================
      {
        "rule_set": "Filter",
        "server": "alidns-quic"
      },

      // ======================================================================
      // 规则11: 广告/DNS劫持规则集 -> 预设返回空响应
      // action: "predefined" + rcode: "NOERROR" 表示返回空响应但不报错
      // 相当于静默丢弃这些DNS请求，实现广告过滤
      // ======================================================================
      {
        "rule_set": [
          "httpDNS",     // HTTP DNS劫持域名
          "DNSreject",   // 需要拒绝的DNS域名
          "Ads"          // 广告域名
        ],
        "action": "predefined",
        "rcode": "NOERROR"    // 返回码: 无错误 (正常响应但不返回IP)
      },

      // ======================================================================
      // 规则12: 拒绝IPv6请求
      // 如果不需要IPv6，可以直接拒绝AAAA记录请求
      // ======================================================================
      {
        "ip_version": 6,      // 匹配IPv6请求
        "action": "reject"    // 拒绝请求
      },

      // ======================================================================
      // 规则13: 拒绝特定DNS查询类型
      // SVCB/HTTPS是新DNS记录类型，PTR是反向解析
      // ======================================================================
      {
        "query_type": [
          "SVCB",    // Service Binding (服务绑定)
          "HTTPS",   // HTTPS记录
          "PTR"      // 反向解析 (IP -> 域名)
        ],
        "action": "reject"
      },

      // ======================================================================
      // 规则14: 拒绝广告规则集中的域名
      // ======================================================================
      {
        "rule_set": [
          "geosite_adguard",           // AdGuard规则集
          "geosite-category-ads-all"   // 全量广告规则集
        ],
        "action": "reject"
      },

      // ======================================================================
      // 规则15: 拒绝Google信标域名
      // beacons用于数据收集和分析
      // ======================================================================
      {
        "domain_suffix": [
          "beacons.gvt2.com",   // Google视频信标
          "beacons2.gvt2.com",
          "beacons3.gvt2.com"
        ],
        "action": "reject"
      },

      // ======================================================================
      // 规则16: 拒绝局域网/内部域名
      // .local, .lan, home等用于内网，不应该向外解析
      // ======================================================================
      {
        "domain_suffix": [
          ".local",
          ".lan",
          "local",
          "lan",
          "home",
          "internal",
          "corp"
        ],
        "action": "reject"
      },

      // ======================================================================
      // 规则17: 兜底规则 - 拒绝非A/AAAA查询
      // invert: true 表示取反，即匹配"不是A和AAAA"的查询
      // 所有其他类型的DNS请求都被拒绝
      // ======================================================================
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "invert": true,    // 反向匹配: 不是A也不是AAAA的查询
        "action": "reject"
      }
    ],

    // ------------------------------------------------------------------------
    // 最终DNS服务器
    // 如果所有规则都不匹配，使用adguard-dns作为默认DNS
    // ========================================================================
    "final": "adguard-dns",

    // ------------------------------------------------------------------------
    // 反向映射
    // 将fakeip映射回原始域名，用于日志和调试
    // ========================================================================
    "reverse_mapping": true,

    // ------------------------------------------------------------------------
    // DNS解析策略
    // prefer_ipv4: 优先返回IPv4地址，减少双栈问题
    // ========================================================================
    "strategy": "prefer_ipv4",

    // ------------------------------------------------------------------------
    // DNS请求超时时间
    // 3秒后未响应则超时
    // ========================================================================
    "timeout": "3s",

    // ------------------------------------------------------------------------
    // DNS缓存容量
    // 256000条记录，约可缓存25万条域名解析结果
    // ========================================================================
    "cache_capacity": 256000,

    // ------------------------------------------------------------------------
    // 乐观DNS缓存
    // 在缓存过期后，先返回旧缓存，同时后台更新，提升响应速度
    // ========================================================================
    "optimistic": {
      "enabled": true,
      "timeout": "1h0m0s"    // 缓存有效期1小时
    }
  },

  // ==========================================================================
  // NTP时间同步模块
  // 确保系统时间准确，对于TLS证书验证很重要
  // ==========================================================================
  "ntp": {
    "enabled": true,           // 启用NTP时间同步
    "interval": "30m0s",       // 每30分钟同步一次
    "server": "ntp.aliyun.com", // 阿里云NTP服务器 (国内快)
    "server_port": 123,        // NTP标准端口
    "detour": "DIRECT"         // 直接连接，不走代理
  },

  // ==========================================================================
  // HTTP客户端配置
  // 用于下载规则集、更新GeoIP等操作
  // ==========================================================================
  "http_clients": [
    {
      "tag": "default",        // 默认HTTP客户端
      "version": 2,            // HTTP/2协议
      "detour": "DIRECT"       // 直连
    },
    {
      "tag": "proxy",          // 代理HTTP客户端
      "version": 2,
      "detour": "PROXY"        // 走代理 (用于下载被墙的规则集)
    }
  ],

  // ==========================================================================
  // 入站配置
  // 定义代理服务器监听的端口和协议
  // ==========================================================================
  "inbounds": [
    // ========================================================================
    // TUN虚拟网卡入站
    // 创建虚拟网卡，接管系统所有流量 (透明代理模式)
    // ========================================================================
    {
      "type": "tun",           // TUN类型 (虚拟网卡)
      "tag": "tun-in",
      "mtu": 1500,             // 最大传输单元，标准以太网值
      "address": "10.8.0.1/24", // TUN网卡IP地址
      "dns_mode": "hijack",    // 劫持DNS流量到内置DNS
      "dns_address": "10.8.0.2", // DNS服务器地址 (fake地址)
      "auto_route": true,      // 自动添加路由表，将所有流量导入TUN
      "strict_route": true,    // 严格路由模式，防止流量泄漏
      "stack": "system"        // 使用系统网络栈 (mixed/gvisor/system)
    },

    // ========================================================================
    // Mixed混合协议入站
    // 同时支持HTTP代理和SOCKS5代理，端口7890
    // ========================================================================
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",   // 只监听本地回环地址
      "listen_port": 7890      // 常见代理端口
    },

    // ========================================================================
    // HTTP代理入站
    // 标准HTTP代理协议，端口7891
    // ========================================================================
    {
      "type": "http",
      "tag": "http-in",
      "listen": "127.0.0.1",
      "listen_port": 7891
    },

    // ========================================================================
    // SOCKS5代理入站
    // 标准SOCKS5协议，端口7892
    // ========================================================================
    {
      "type": "socks",
      "tag": "socks-in",
      "listen": "127.0.0.1",
      "listen_port": 7892
    },

    // ========================================================================
    // Redirect透明代理入站
    // 用于iptables重定向的透明代理模式
    // ========================================================================
    {
      "type": "redirect",
      "tag": "redirect-in",
      "listen": "127.0.0.1",
      "listen_port": 7893
    }
  ],

  // ==========================================================================
  // 出站配置
  // 定义流量的出口方式 (直连/代理/拒绝等)
  // ==========================================================================
  "outbounds": [
    // ========================================================================
    // 直连出站
    // 直接连接，不经过任何代理
    // ========================================================================
    {
      "type": "direct",
      "tag": "DIRECT",
      "domain_resolver": "alidns-quic"  // 使用阿里DNS解析直连域名
    },

    // ========================================================================
    // 选择器出站 (手动模式)
    // 用户可以通过API选择使用哪个节点
    // ========================================================================
    {
      "type": "selector",
      "tag": "PROXY",
      "outbounds": [
        "🟢 自动-测速",    // 自动选择最快节点
        "🔵 自动-稳定",    // 自动选择稳定节点
        "//节点名称",      // 这里会被替换为实际节点名称
        "DIRECT"          // 可选直连
      ],
      "default": "🟢 自动-测速"  // 默认使用测速组
    },

    // ========================================================================
    // 延迟测速出站 (最快节点)
    // 自动测试所有节点的延迟，选择最低延迟的节点
    // ========================================================================
    {
      "type": "urltest",
      "tag": "🟢 自动-测速",
      "outbounds": [
        "//节点名称"       // 节点列表占位符
      ],
      "url": "http://www.gstatic.com/generate_204",  // 测速URL (Google连通性测试)
      "interval": "10m0s",    // 每10分钟测速一次
      "tolerance": 100,       // 延迟容忍度100ms (延迟差在100ms内不切换)
      "idle_timeout": "30m0s" // 空闲30分钟后停止测速
    },

    // ========================================================================
    // 延迟测速出站 (稳定节点)
    // 使用更大的tolerance值(30ms)，减少节点切换，更稳定
    // ========================================================================
    {
      "type": "urltest",
      "tag": "🔵 自动-稳定",
      "outbounds": [
        "//节点名称"
      ],
      "url": "http://www.gstatic.com/generate_204",
      "interval": "15m0s",
      "tolerance": 30,         // 30ms容忍度，更稳定
      "idle_timeout": "1h0m0s"
    },

    // ========================================================================
    // QUIC/UDP专用选择器
    // 用于处理QUIC协议流量 (如HTTP/3)
    // ========================================================================
    {
      "type": "selector",
      "tag": "🟣 QUIC-UDP",
      "outbounds": [
        "//节点名称"
      ],
      "default": "//节点名称"
    },

    // ========================================================================
    // 最终出站选择器
    // 处理规则未匹配到的流量
    // ========================================================================
    {
      "type": "selector",
      "tag": "Final",
      "outbounds": [
        "PROXY",          // 默认走代理
        "DIRECT",         // 可选直连
        "REJECT-DROP"     // 可选拒绝
      ],
      "default": "PROXY"
    },

    // ========================================================================
    // 阻止出站
    // 丢弃所有流量 (不会响应，静默丢弃)
    // ========================================================================
    {
      "type": "block",
      "tag": "REJECT-DROP"
    }

    // ========================================================================
    // 注意: 实际节点配置应该写在这里
    // 节点格式示例:
    // {
    //   "type": "vmess",
    //   "tag": "节点名称",
    //   "server": "example.com",
    //   "server_port": 443,
    //   "uuid": "xxxxx",
    //   "security": "auto",
    //   "tls": { "enabled": true }
    // }
    // ========================================================================
  ],

  // ==========================================================================
  // 路由配置
  // 核心模块: 根据规则决定流量走向 (代理/直连/拒绝)
  // ==========================================================================
  "route": {
    // ------------------------------------------------------------------------
    // 路由规则列表
    // 按顺序匹配，命中后执行对应action或outbound
    // ------------------------------------------------------------------------
    "rules": [
      // ======================================================================
      // 规则1: 流量嗅探
      // 分析连接的首个数据包，识别TLS SNI、HTTP Host等
      // ======================================================================
      {
        "action": "sniff"
      },

      // ======================================================================
      // 规则2: DNS流量劫持
      // 匹配端口53或协议dns的流量，劫持到内置DNS服务器
      // ======================================================================
      {
        "type": "logical",
        "mode": "or",          // 逻辑或: 满足任一条件即匹配
        "rules": [
          {
            "port": 53         // 标准DNS端口
          },
          {
            "protocol": "dns"  // DNS协议
          }
        ],
        "action": "hijack-dns" // 劫持到内置DNS
      },

      // ======================================================================
      // 规则3: 拒绝非标准DNS端口
      // 853是DOT端口，5353是mDNS端口
      // ======================================================================
      {
        "port": [
          853,                 // DNS over TLS
          5353                 // mDNS (多播DNS)
        ],
        "action": "reject"
      },

      // ======================================================================
      // 规则4: Google Play相关QUIC流量 -> 丢弃
      // QUIC是HTTP/3使用的协议，这里专门处理Play商店的QUIC流量
      // ======================================================================
      {
        "type": "logical",
        "mode": "and",         // 逻辑与: 必须同时满足两个条件
        "rules": [
          {
            "protocol": "quic" // 条件1: 协议是QUIC
          },
          {
            "domain_suffix": [ // 条件2: 域名后缀匹配
              "play.google.com",
              "play.googleapis.com",
              "play-fe.googleapis.com",
              "play-lh.googleusercontent.com",
              "play-apps-features.googleusercontent.com",
              "ggpht.com",
              "googleusercontent.com"
            ]
          }
        ],
        "action": "reject",
        "method": "drop"       // 静默丢弃，不返回任何响应
      },

      // ======================================================================
      // 规则5: 海外服务的QUIC流量 -> 转发到QUIC专用出站
      // 确保QUIC/UDP流量走正确的代理节点
      // ======================================================================
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "protocol": "quic"
          },
          {
            "type": "logical",
            "mode": "or",
            "rules": [
              {
                "rule_set": [    // 匹配规则集中的域名
                  "geosite-google",
                  "geosite-youtube",
                  "instagram",
                  "telegram",
                  "Google",
                  "Proxy",
                  "gfw",
                  "ai",
                  "games",
                  "GlobalMedia",
                  "proxy"
                ]
              },
              {
                "domain_suffix": [  // 匹配具体的域名后缀
                  "play.google.com",
                  "play.googleapis.com",
                  "play-fe.googleapis.com",
                  "play-lh.googleusercontent.com",
                  "android.clients.google.com",
                  "android.googleapis.com",
                  "dl.google.com",
                  "dl.l.google.com",
                  "gvt1.com",
                  "gvt2.com",
                  "gvt3.com",
                  "ggpht.com",
                  "googleusercontent.com",
                  "twitter.com",
                  "twimg.com",
                  "facebook.com",
                  "fbcdn.net",
                  "netflix.com",
                  "spotify.com",
                  "github.com",
                  "steampowered.com",
                  "discord.com",
                  "reddit.com",
                  "tiktok.com",
                  "amazon.com",
                  "paypal.com"
                ]
              }
            ]
          }
        ],
        "outbound": "🟣 QUIC-UDP"  // 转发到QUIC专用出站
      },

      // ======================================================================
      // 规则6: Google推送服务 (FCM) -> 走代理
      // mtalk.google.com是Google推送服务的关键域名
      // ======================================================================
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "domain_suffix": [
              "mtalk.google.com",
              "alt1-mtalk.google.com",
              "alt2-mtalk.google.com",
              "alt3-mtalk.google.com",
              "alt4-mtalk.google.com",
              "alt5-mtalk.google.com",
              "alt6-mtalk.google.com",
              "alt7-mtalk.google.com",
              "alt8-mtalk.google.com"
            ]
          },
          {
            "port": [          // 匹配推送服务的端口
              443,             // HTTPS端口
              5228             // FCM专用端口
            ]
          }
        ],
        "outbound": "PROXY"
      },

      // ======================================================================
      // 规则7: 特定Android应用包名 -> 走代理
      // 使用正则表达式匹配应用包名
      // ======================================================================
      {
        "package_name_regex": "^(com\\.google\\.android\\.(youtube|apps\\.(maps|docs|drive|photos))|app\\.revanced\\.android\\.youtube|org\\.telegram\\.messenger(\\..*)?)$",
        "outbound": "PROXY"
      },

      // ======================================================================
      // 规则8: IP/DNS泄漏测试网站 -> 走代理
      // 访问这些网站时强制走代理，确保测试结果正确
