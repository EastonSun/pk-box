    // --- 最终兜底路由 (所有版本共有，但行为不同) ---
    // 所有版本均指向 "Final" 出站组。
    // ★ 差异点：Final 组的默认出站不同。优化版和标准版默认 "PROXY"；特殊版默认 "REJECT-DROP"。
    // 这意味着在特殊版中，所有未匹配规则的流量默认都会被直接丢弃，不会产生网络连接。这是一种非常安全、零泄露的配置，但也意味着如果某个网站没被规则覆盖，将无法访问。
    "final": "Final",

    "auto_detect_interface": true, // 自动检测网卡
    // ★ 差异点：默认域名解析器。优化版和标准版->alidns-quic；特殊版->adguard-dns。
    "default_domain_resolver": "alidns-quic"
  },

  // ==========================================
  // 实验性模块 (所有版本基本相同)
  // ==========================================
  "experimental": {
    // 缓存文件：用于持久化 DNS 缓存和 FakeIP 映射，重启后无需重新积累缓存，提升启动速度。
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      "cache_id": "cinchov", // 缓存标识，可用于区分不同配置
      "store_fakeip": true,  // 将 FakeIP 映射存入数据库
      "store_dns": true      // 将 DNS 缓存存入数据库
    },
    // Clash API：开启后可使用 Clash 的仪表板（如 yacd）来控制 sing-box。
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "ui",     // 仪表板文件路径，通常是下载的 yacd 文件夹
      "default_mode": "rule"  // 默认模式为规则
    },
    // 调试设置：优化内存管理。
    "debug": {
      "gc_percent": 100,      // 内存增长 100% 时触发 GC，更频繁地回收内存
      "memory_limit": "400MB" // 设置内存上限（软限制）
    }
  }
  // --- 配置结束 ---
  // 特别说明：
  // 1. FakeIP 路由：`198.18.0.0/15` 的流量在路由规则中被强制走向 "PROXY" 组。这意味着，只要 DNS 将某域名解析到了 FakeIP，设备上的后续连接就会被自动路由到代理。
  // 2. 特殊版的安全性：特殊版的 `Final` 默认为 `REJECT-DROP`，且大量依赖 `adguard-dns` 作为 DNS 服务器。这意味着它构建了一个防御性极强的环境，几乎只允许规则集中明确定义的网站访问。
  // 3. 关于 `evaluate` 的疑惑：在 DNS 规则中使用 `evaluate`，标准文档中并未详细说明其与直接 `server` 的区别。推测是将结果用于下一阶段的规则匹配（特别是 `match_response`），但在此配置中，后续紧跟的规则可能使其效果与直接指定 server 差异不大，更多是原作者的一种多重保险写法。
}

{
  "配置文件对比总结": {
    "版本号": "1.14.0-alpha.21",
