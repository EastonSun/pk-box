      { "type": "remote", "tag": "ai", "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/ai.srs", /*...省略...*/ },
      { "type": "remote", "tag": "private", "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/private.srs", /*...省略...*/ },
      { "type": "remote", "tag": "anti_fraud", "url": "https://raw.githubusercontent.com/hwsaya/nothing/refs/heads/main/rules/FuckFZ.json", /*...省略...*/ },
      { "type": "remote", "tag": "cn", "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/cn.srs", /*...省略...*/ },
      { "type": "remote", "tag": "microsoft-cn", "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/microsoft-cn.srs", /*...省略...*/ },
      { "type": "remote", "tag": "apple-cn", "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/apple-cn.srs", /*...省略...*/ },
