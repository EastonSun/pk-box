{
  // ╔══════════════════════════════════════════════════════════════╗
  // ║             sing-box 1.14.0-alpha.25 完整配置               ║
  // ║                  小白也能看懂的逐行注释                      ║
  // ╚══════════════════════════════════════════════════════════════╝
  //
  // 📌 这个文件做什么的？
  //    让手机所有流量经过代理，同时国内网站直连（快），国外网站走代理（安全）
  //    DNS不泄露，广告被拦截，IP被隐藏
  //
  // 📌 怎么用？
  //    把本文件改名为 25.json，在sing-box中启动即可
  //    注意：// 注释是 sing-box 支持的，但标准JSON不支持
  //
  // ═══════════════════════════════════════════════════════════════

  // ┌─────────────────────────────────────────────────────────────┐
  // │ 1. 日志设置 (log)                                           │
  // │    控制sing-box输出多少日志信息                              │
  // └─────────────────────────────────────────────────────────────┘
  "log": {
    // 日志级别: trace=全部(调试用) | debug=详细 | info=一般 | warn=警告 | error=错误
    // 💡 日常用warn即可，出问题时改debug排查
    "level": "warn",
    // 每条日志前面加时间戳，方便看什么时候发生的
    "timestamp": true
  },

  // ┌─────────────────────────────────────────────────────────────┐
  // │ 2. DNS 设置 (dns)                                           │
  // │    最核心的反泄露机制！控制所有域名解析怎么走                 │
  // └─────────────────────────────────────────────────────────────┘
  "dns": {
    // ── 2.1 DNS 服务器列表 ──
    // 每个服务器是一个"DNS解析工人"，负责查询域名对应的IP
    "servers": [
      // ─── hosts_fix: 本地Hosts表 ───
      // 类似电脑的 /etc/hosts 文件，直接写死域名→IP，不走网络
      // 🎯 作用：DNS服务器自己需要解析域名才能连接，用hosts表避免鸡生蛋问题
      {
        "type": "hosts",                    // hosts类型=本地域名表
        "tag": "hosts_fix",                 // 标签名，后面引用用这个名字
        "predefined": {
          // 华为云DNS的IP（备用）
          "dns.huaweicloud.com": ["180.163.150.33", "180.163.151.33"],
          // 阿里DNS的IP → 国内DoH/DoQ服务器用
          "dns.alidns.com": ["223.5.5.5", "223.6.6.6"],
          // AdGuard DNS的IP → 去广告DNS服务器用
          "dns.adguard.com": ["94.140.14.15", "94.140.15.16"],
          // DNSPod(腾讯)的DoH地址 → 国内DoH服务器用
          "doh.pub": ["1.12.12.21", "120.53.53.53"],
          // Google DNS的IP → 国外DNS服务器用
          "dns.google": ["8.8.8.8", "8.8.4.4"],
          // Cloudflare DNS的IP → 国外DoT/DoH服务器用
          "cloudflare-dns.com": ["104.16.248.249", "104.16.249.249"],
          "dns.cloudflare.com": ["104.16.248.249", "104.16.249.249"],
          // Quad9 DNS的IP → 国外DoH服务器用
          "dns.quad9.net": ["9.9.9.9", "149.112.112.112"],
          // Google FCM推送服务 → 手机收消息依赖它
          "mtalk.google.com": ["142.250.107.188", "142.251.170.188", "108.177.125.188"],
          "alt1-mtalk.google.com": "74.125.200.188",
          // Google下载CDN → 加速Google Play等下载
          "dl.google.com": "180.163.151.161",
          "dl.l.google.com": "180.163.150.33"
        }
      },

      // ─── alidns-quic: 阿里DNS(DoQ加密) ───
      // 🎯 主引导DNS！所有代理节点用它解析自己的服务器域名
      // ⚡ 走DIRECT直连，速度最快（<10ms），DoQ加密内容不可见
      // ⚠️ 绝对不能改PROXY，否则节点无法引导（鸡生蛋死锁）
      {
        "type": "quic",                     // QUIC协议=UDP版HTTP3，比传统DNS更快
        "tag": "alidns-quic",
        "detour": "DIRECT",                 // 走直连（不走代理），因为节点需要它来引导
        "domain_resolver": "hosts_fix",     // 解析 dns.alidns.com 时用hosts表，不走网络
        "server": "dns.alidns.com"          // 阿里云公共DNS
      },

      // ─── dnspub-doh: 腾讯DNSPod(DoH加密) ───
      // 🎯 解析国内 private 规则集中的域名
      // ⚡ 走DIRECT，DoH加密（TLS包装HTTP），运营商看不见查询内容
      {
        "type": "https",                    // DoH = DNS over HTTPS，HTTPS加密的DNS
        "tag": "dnspub-doh",
        "detour": "DIRECT",
        "domain_resolver": "hosts_fix",
        "server": "doh.pub"                 // 腾讯公共DNS
      },

      // ─── tx-doh: 同上(另一标签) ───
      // 🎯 解析国内 cn 规则集中的域名
      // 💡 为什么和dnspub-doh一样却要两个？因为不同标签对应不同DNS规则，方便调试
      {
        "type": "https",
        "tag": "tx-doh",
        "detour": "DIRECT",
        "domain_resolver": "hosts_fix",
        "server": "doh.pub"
      },

      // ─── ali-doh: 阿里DNS(DoH加密) ───
      // 🎯 解析 .cn / .com.cn 后缀的域名
      {
        "type": "https",
        "tag": "ali-doh",
        "detour": "DIRECT",
        "domain_resolver": "hosts_fix",
        "server": "dns.alidns.com"
      },

      // ─── ggdns: Google DNS(DoH) ───
      // 🎯 解析需要走代理的域名（通过Google DNS避免DNS污染）
      // 🔒 走PROXY代理，全程加密
      {
        "type": "https",
        "tag": "ggdns",
        "detour": "PROXY",                  // 走代理隧道！
        "domain_resolver": "hosts_fix",
        "server": "dns.google"              // 8.8.8.8的DoH版
      },

      // ─── cf-dot: Cloudflare DNS(DoT加密) ───
      // 🎯 解析 GlobalMedia 规则集（Netflix/Spotify等流媒体）
      // DoT = DNS over TLS，比DoH更轻量
      {
        "type": "tls",                      // DoT协议，TLS直连DNS
        "tag": "cf-dot",
        "detour": "PROXY",
        "domain_resolver": "hosts_fix",
        "server": "cloudflare-dns.com",     // 1.1.1.1的DoT版
        "server_port": 853                  // DoT默认端口
      },

      // ─── quad9-doh: Quad9 DNS(DoH) ───
      // 🎯 解析 Google/YouTube 相关域名（备用）
      // Quad9=9.9.9.9，特点：自带恶意域名过滤
      {
        "type": "https",
        "tag": "quad9-doh",
        "detour": "PROXY",
        "domain_resolver": "hosts_fix",
        "server": "dns.quad9.net"
      },

      // ─── doh-ech: Cloudflare ECH加密DNS ───
      // 🎯 解析 fff.372164885.xyz 专用
      // ECH = 加密ClientHello，连SNI都隐藏，最彻底的DNS加密
      {
        "type": "https",
        "tag": "doh-ech",
        "detour": "PROXY",
        "domain_resolver": "hosts_fix",
        "server": "dns.cloudflare.com"
      },

      // ─── adguard-dns: AdGuard DNS(DoH) ───
      // 🎯 最终兜底DNS，自带去广告功能
      // 🔒 走PROXY，所有不匹配其他规则的域名最终到这里
      {
        "type": "https",
        "tag": "adguard-dns",
        "detour": "PROXY",
        "domain_resolver": "hosts_fix",
        "server": "dns.adguard.com"
      },

      // ─── fakeip: 虚拟IP(FakeIP) ───
      // 🎯 游戏/视频/CDN大流量专用，不真正查DNS，直接返回虚拟IP
      // 💡 原理：域名→随机返回198.18.x.x的假IP→连接时再查真实IP
      // ⚡ 好处：DNS零延迟，适合游戏下载/视频缓冲
      {
        "type": "fakeip",
        "tag": "fakeip",
        "inet4_range": "198.18.0.0/15",     // IPv4虚拟地址池（13万+个IP）
        "inet6_range": "fc00::/18"          // IPv6虚拟地址池
      }
    ],

    // ── 2.2 DNS 规则 ──
    // ⚠️ 规则从上到下匹配，命中第一条就停止！
    // 所以：拒绝类放最前面 > 国内 > 国外 > 兜底
    "rules": [
      // 规则1: 🛡️ 拒绝非标准DNS查询类型
      // SVCB/HTTPS=HTTP3相关，PTR=反向查询，都先拦掉防止泄露
      {
        "query_type": ["SVCB", "HTTPS", "PTR"],
        "action": "reject"                  // 直接拒绝
      },

      // 规则2: 🛡️ 广告域名 → 直接拒绝（DNS层拦截广告）
      // geosite_adguard = AdGuard规则集，geosite-category-ads-all = 全量广告规则
      {
        "rule_set": ["geosite_adguard", "geosite-category-ads-all"],
        "action": "reject"
      },

      // 规则3: 🛡️ 广告/跟踪器正则匹配 → 拒绝
      // 用正则表达式匹配域名中的广告关键词
      {
        "domain_regex": "^(ad|ads|advert|banner|sponsor|popup|tracker|analytics)\\.|doubleclick\\.|googleadservices\\.|googlesyndication\\.",
        "action": "reject"
      },

      // 规则4: 🛡️ 具体广告域名通配符 → 拒绝
      // doubleclick = Google广告，openx = 广告交易平台 等
      {
        "domain": [
          "*.doubleclick.net",
          "*.googlesyndication.com",
          "*.googleadservices.com",
          "*.adservice.google.com",
          "*.addthis.com",
          "*.adnxs.com",
          "*.adsrvr.org",
          "*.casalemedia.com",
          "*.rubiconproject.com",
          "*.openx.net"
        ],
        "action": "reject"
      },

      // 规则5: 🛡️ Google信标域名 → 拒绝
      // Chrome用来上报数据的域名，拦掉保护隐私
      {
        "domain_suffix": ["beacons.gvt2.com", "beacons2.gvt2.com", "beacons3.gvt2.com"],
        "action": "reject"
      },

      // 规则6: 🛡️ 本地/mDNS域名 → 拒绝
      // .local .lan 等是局域网mDNS域名（打印机/NAS等），由系统mDNS(5353端口)处理
      // 不需要经过公共DNS，直接拒绝
      {
        "domain_suffix": [".local", ".lan", "local", "lan", "home", "internal", "corp", "example.com"],
        "action": "reject"
      },

      // 规则7: 🎮 Steam局域网缓存 → 国内DNS
      // lancache是Steam的局域网下载缓存服务器
      {
        "domain_suffix": "lancache.steamcontent.com",
        "server": "alidns-quic"
      },

      // 规则8: 🪟 微软网络连通性检测 → 国内DNS
      // Windows/Office用来检测网络是否在线的域名
      {
        "domain_suffix": ["msftncsi.com", "msftconnecttest.com"],
        "server": "alidns-quic"
      },

      // 规则9: 🇨🇳 国内域名规则集 → 腾讯DoH
      // cn.srs 包含百度/淘宝/京东等所有中国大陆域名
      {
        "rule_set": "cn",
        "server": "tx-doh"                  // 腾讯DoH(DIRECT)
      },

      // 规则10: 🏠 私有/局域网域名 → 腾讯DoH
      // private.srs 包含局域网/内网域名
      {
        "rule_set": "private",
        "server": "dnspub-doh"              // 腾讯DoH(DIRECT)
      },

      // 规则11: 🚫 FakeIP过滤规则集 → 阿里DoQ
      // ⚠️ 这个必须在FakeIP规则之前！
      // Filter.srs 里的域名不应该走FakeIP（如银行/支付类需要真实IP），所以先匹配到这里
      {
        "rule_set": ["Filter"],
        "server": "alidns-quic"
      },

      // 规则12: 🇨🇳 .cn / .com.cn 后缀 → 阿里DoH
      // 所有以.cn结尾的中国域名
      {
        "domain_suffix": [".cn", ".com.cn"],
        "server": "ali-doh"                 // 阿里DoH(DIRECT)
      },

      // 规则13: 🎮 游戏平台 → FakeIP（零延迟）
      // Steam/Epic/GOG/Origin/Uplay/Play商店 等游戏和下载平台
      {
        "query_type": ["A", "AAAA"],        // 只处理IPv4(A)和IPv6(AAAA)查询
        "domain_suffix": [
          "steamcontent.com",               // Steam下载CDN
          "steamserver.net",                // Steam服务器
          "epicgames.com",                  // Epic游戏商城
          "gog.com",                        // GOG游戏平台
          "battle.net",                     // 暴雪战网
          "blizzard.com",                   // 暴雪
          "origin.com",                     // EA Origin
          "ea.com",                         // EA
          "ubisoft.com",                    // 育碧
          "rockstargames.com",              // Rockstar
          "play.google.com",                // Google Play商店
          "ggpht.com",                      // Google Play CDN
          "googleusercontent.com",          // Google用户内容CDN
          "android.com",                    // Android系统
          "app-measurement.com",            // Firebase分析
          "firebaselogging.googleapis.com", // Firebase日志
          "firebaselogging-pa.googleapis.com"
        ],
        "server": "fakeip"                  // 返回198.18.x.x虚拟IP
      },

      // 规则14: 🔍 Google/YouTube等大厂 → FakeIP（零延迟）
      // Google全家桶 + Twitter + Facebook + Instagram
      {
        "query_type": ["A", "AAAA"],
        "domain_suffix": [
          "google.com",                     // Google搜索
          "google.com.hk",                  // Google香港
          "googleapis.com",                 // Google API
          "gstatic.com",                    // Google静态资源
          "ggpht.com",                      // Google图片CDN
          "youtube.com",                    // YouTube
          "ytimg.com",                      // YouTube图片
          "googlevideo.com",                // YouTube视频CDN
          "twitter.com",                    // Twitter/X
          "twimg.com",                      // Twitter图片
          "facebook.com",                   // Facebook
          "fbcdn.net",                      // Facebook CDN
          "instagram.com",                  // Instagram
          "cdninstagram.com"                // Instagram CDN
        ],
        "server": "fakeip"
      },

      // 规则15: 🌍 代理规则集 → FakeIP
      // telegram/YouTube/Instagram/Proxy/gfw/AI/游戏/GlobalMedia
      {
        "query_type": ["A", "AAAA"],
        "rule_set": [
          "telegram",                       // Telegram
          "geosite-youtube",                // YouTube域名
          "instagram",                      // Instagram域名
          "Proxy",                          // 需要代理的域名(!cn)
          "gfw",                            // GFW封锁域名
          "ai",                             // AI服务(ChatGPT/Claude等)
          "games",                          // 游戏域名
          "GlobalMedia"                     // 全球流媒体
        ],
        "server": "fakeip"
      },

      // 规则16: 🔍 Google/YouTube → Quad9 DoH（FakeIP的备用）
      // 如果FakeIP出问题，走Quad9 DNS解析
      {
        "rule_set": ["geosite-google", "geosite-youtube"],
        "server": "quad9-doh"               // Quad9 DoH(PROXY)
      },

      // 规则17: 🎬 全球流媒体 → Cloudflare DoT
      // Netflix/Spotify/Disney+ 等流媒体
      {
        "rule_set": "GlobalMedia",
        "server": "cf-dot"                  // Cloudflare DoT(PROXY)
      },

      // 规则18: 🤖 proxy/games/ai → FakeIP（带TTL重写）
      // rewrite_ttl=300表示DNS缓存5分钟，过期重新查
      {
        "query_type": ["A", "AAAA"],
        "rule_set": ["proxy", "games", "ai"],
        "server": "fakeip",
        "rewrite_ttl": 300                  // TTL重写为300秒
      },

      // 规则19: 🛡️ HTTPDNS/广告DNS → 返回空(NOERROR但不给IP)
      // 让App以为DNS成功但拿不到IP，从而放弃连接
      {
        "rule_set": ["httpDNS", "DNSreject", "Ads"],
        "action": "predefined",             // 预设响应
        "rcode": "NOERROR"                  // DNS返回码：成功（但不给IP地址）
      },

      // 规则20: 🔗 特殊域名 → ECH加密DNS
      // fff.372164885.xyz 使用最安全的ECH DNS
      {
        "domain_suffix": "fff.372164885.xyz",
        "server": "doh-ech"                 // Cloudflare ECH DoH(PROXY)
      },

      // 规则21: 🛡️ 拒绝所有非A/AAAA查询（除上面已匹配的）
      // invert=true = 取反，即"不是A也不是AAAA"的查询全部拒绝
      // 💡 前面已经放行了特定规则的非A/AAAA查询，剩下的全部拦截
      {
        "query_type": ["A", "AAAA"],
        "invert": true,                     // 取反！不是A/AAAA的都拦截
        "action": "reject"
      },

      // 规则22: 🛡️ 广告规则集 → 阿里DoH（DNS层）
      // 和规则2的区别：这里返回阿里DNS的结果而非直接拒绝
      {
        "rule_set": ["geosite_adguard", "geosite-category-ads-all"],
        "server": "ali-doh"
      }
    ],

    // ── 2.3 DNS 全局设置 ──
    // 兜底DNS：所有规则都没匹配的域名，用 cf-dot 解析
    // 💡 之前用adguard-dns，现在改用cf-dot更稳定
    "final": "cf-dot",

    // 反向映射：IP→域名反查，FakeIP需要它来还原真实域名
    "reverse_mapping": true,

    // DNS策略：优先返回IPv4地址（手机IPv6不稳定）
    "strategy": "prefer_ipv4",

    // DNS查询超时：3秒没回复就换服务器
    "timeout": "3s",

    // DNS缓存容量：最多缓存256000条记录
    "cache_capacity": 256000,

    // DNS乐观缓存：缓存过期1小时内仍可使用，极大加速重复访问
    "optimistic": {
      "enabled": true,
      "timeout": "1h0m0s"                   // 过期后1小时内仍乐观使用
    }
  },

  // ┌─────────────────────────────────────────────────────────────┐
  // │ 3. NTP 时间同步                                             │
  // │    手机时间不准会影响TLS证书验证，定期同步很重要             │
  // └─────────────────────────────────────────────────────────────┘
  "ntp": {
    "enabled": true,                        // 开启时间同步
    "interval": "30m0s",                    // 每30分钟同步一次
    "server": "ntp.aliyun.com",             // 阿里云授时服务器
    "server_port": 123,                     // NTP默认端口
    "detour": "PROXY"                       // 走代理（防止时间戳泄露）
  },

  // ┌─────────────────────────────────────────────────────────────┐
  // │ 4. HTTP 客户端                                              │
  // │    用来下载规则集等文件，类似浏览器下载                      │
  // └─────────────────────────────────────────────────────────────┘
  "http_clients": [
    // default: 默认下载器（DIRECT直连）
    // 用于下载 jsdelivr CDN 上的规则集（国内CDN快）
    {
      "tag": "default",
      "version": 2,                         // HTTP/2
      "detour": "DIRECT",                   // 直连下载
      "stream_receive_window": 0,           // 0=自动
      "connection_receive_window": 0
    },
    // proxy: 代理下载器（PROXY）
    // 💡 备用，如果jsdelivr挂了可以切到这个
    {
      "tag": "proxy",
      "version": 2,
      "detour": "PROXY",                    // 走代理下载
      "domain_resolver": "alidns-quic",     // 用阿里DNS解析下载地址
      "stream_receive_window": 0,
      "connection_receive_window": 0
    }
  ],

  // ┌─────────────────────────────────────────────────────────────┐
  // │ 5. 入站 (inbounds)                                          │
  // │    手机流量怎么"进来"被sing-box接管                          │
  // └─────────────────────────────────────────────────────────────┘
  "inbounds": [
    // ── TUN入站：接管所有手机流量（最重要！） ──
    // 原理：创建虚拟网卡，所有App流量经过它 → 被sing-box处理
    {
      "type": "tun",                        // TUN = 虚拟网卡模式
      "tag": "tun-in",
      "mtu": 1500,                          // 最大传输单元（标准值）
      "address": "10.8.0.1/24",             // 虚拟网卡的IP地址
      "dns_mode": "hijack",                 // DNS劫持模式：拦截所有53端口DNS请求
      "dns_address": "10.8.0.2",            // 虚拟DNS服务器地址
      "auto_route": true,                   // 自动设置路由规则
      "strict_route": true,                 // 严格路由（防止流量绕过）
      "stack": "system"                     // 使用系统TCP/IP协议栈
    },

    // ── 混合入站(HTTP+SOCKS) :7890 ──
