  // ┌─────────────────────────────────────────────────────────────┐
  // │ 7. 路由 (route)                                             │
  // │    决定流量走直连(DIRECT)还是代理(PROXY)                    │
  // │    ⚠️ 规则从上到下匹配，命中第一条就停！                    │
  // └─────────────────────────────────────────────────────────────┘
  "route": {
    "rules": [
      // 规则0: 🔍 第一步：嗅探协议
      // 用第一个数据包判断是什么协议（TLS/HTTP/DNS等）
      {
        "action": "sniff"
      },

      // 规则1: 🔒 DNS劫持（53端口 + DNS协议）
      // 把普通DNS查询劫持到sing-box内部DNS模块 → 防泄露！
      {
        "type": "logical",
        "mode": "or",                       // 满足任一条件就命中
        "rules": [
          { "port": 53 },                   // 53端口（标准DNS）
          { "protocol": "dns" }             // DNS协议（嗅探出来的）
        ],
        "action": "hijack-dns"              // 劫持到内部DNS
      },

      // 规则2: 🚫 拒绝 DoT(853) 和 mDNS(5353)
      // DoT=DNS over TLS，加密DNS绕过劫持 → 拒绝让它回退到53
      // mDNS=局域网设备发现，由系统处理，不需要过代理
      {
        "port": [853, 5353],
        "action": "reject"
      },

      // 规则3: 🚫 拒绝无效IPv6公网地址
      // 路由器没有分配IPv6公网地址(2000::/3)时，拒绝所有IPv6流量
      // 💡 避免IPv6直连泄露
      {
        "type": "logical",
        "mode": "and",                      // 两个条件都要满足
        "rules": [
          { "ip_version": 6 },              // IPv6流量
          { "default_interface_address": "2000::/3", "invert": true }  // 没有公网IPv6
        ],
        "action": "reject"
      },

      // 规则4: 🇨🇳 B站全家桶 → DIRECT
      {
        "domain_suffix": [
          "api.bilibili.com",
          "www.bilibili.com",
          "bilivideo.com",
          "hdslb.com",
          "bilicdn1.com",
          "bilicdn.com"
        ],
        "outbound": "DIRECT"
      },

      // 规则5: 🇨🇳 短视频平台 → DIRECT
      {
        "domain_suffix": ["xiaohongshu.com", "xhscdn.com", "kuaishou.com", "ixigua.com"],
        "outbound": "DIRECT"
      },

      // 规则6: ⏱️ NTP时间同步 + ICMP Ping → DIRECT
      {
        "protocol": ["ntp", "icmp"],
        "outbound": "DIRECT"
      },

      // 规则7: 📱 SponsorBlock/系统OTA等 → DIRECT
      {
        "domain_suffix": [
          "sponsor.ajay.app",               // SponsorBlock（去广告插件）
          "ifbapp.com",
          "allawnos.com",
          "heytapmobi.com",                 // OPPO/一加系统
          "steamserver.net"
        ],
        "outbound": "DIRECT"
      },

      // 规则8: 🔒 泄露检测站点 → PROXY
      // 这些站点必须走代理！否则它们会看到你的真实IP
      // 💡 这条必须在下方规则9(DIRECT)之前！
      {
        "domain_suffix": [
          "browserleaks.com",               // DNS/WebRTC泄露检测
          "ipleak.net",                     // IP泄露检测
          "dnsleaktest.com",                // DNS泄露检测
          "whoer.net",                      // 匿名度检测
          "whatleaks.com",                  // 综合泄露检测
          "ip.sb",                          // IP查询
          "ipinfo.io",                      // IP信息
          "ifconfig.me",                    // IP查询
          "ip-api.com"                      // IP地理信息
        ],
        "outbound": "PROXY"
      },

      // 规则9: 🇨🇳 国内规则集 → DIRECT
      // private=私有IP, cn=中国域名, cnip=中国IP
      // microsoft-cn=微软中国, apple-cn=苹果中国, games-cn=中国游戏
      // networktest=网速测试站点
      {
        "rule_set": [
          "private", "cn", "cnip",
          "microsoft-cn", "apple-cn", "games-cn", "networktest"
        ],
        "outbound": "DIRECT"
      },

      // 规则10: 🇨🇳 国内大厂域名 → DIRECT
      {
        "domain_suffix": [
          "alipay.com",                     // 支付宝
          "alicdn.com",                     // 阿里CDN
          "aliyuncs.com",                   // 阿里云OSS
          "qcloud.com",                     // 腾讯云
          "cloud.tencent.com",              // 腾讯云
          "mi.com", "xiaomi.com",           // 小米
          "huawei.com",                     // 华为
          "vivo.com.cn",                    // vivo
          "oppo.com",                       // OPPO
          "coolapk.com",                    // 酷安
          "wps.cn",                         // WPS
          "biliapi.com"                     // B站API
        ],
        "outbound": "DIRECT"
      },

      // 规则11: 📱 App白名单 → DIRECT（按包名匹配）
      // 微信、支付宝、网易云音乐 走直连
      {
        "package_name": [
          "com.tencent.mm",                 // 微信
          "com.eg.android.AlipayGphone",    // 支付宝
          "com.netease.cloudmusic"          // 网易云音乐
        ],
        "outbound": "DIRECT"
      },

      // 规则12: 📱 悦行宝 → DIRECT
      {
        "package_name": "com.wwwscn.yuexingbao",
        "outbound": "DIRECT"
      },

      // 规则13: 🎛️ Clash模式切换 → Direct模式走直连
      {
        "clash_mode": "Direct",
        "outbound": "DIRECT"
      },

      // 规则14: 🍎 Apple规则集 → DIRECT
      {
        "rule_set": "Apple",
        "outbound": "DIRECT"
      },

      // 规则15: 📲 Google FCM推送 → PROXY
      // 同时满足：域名是mtalk.google.com + 端口是443或5228
      // 💡 只代理FCM推送的特定端口，不影响其他Google服务
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          { "domain_suffix": ["mtalk.google.com",
              "alt1-mtalk.google.com","alt2-mtalk.google.com",
              "alt3-mtalk.google.com","alt4-mtalk.google.com",
              "alt5-mtalk.google.com","alt6-mtalk.google.com",
              "alt7-mtalk.google.com","alt8-mtalk.google.com"]
          },
          { "port": [443, 5228] }
        ],
        "outbound": "PROXY"
      },

      // 规则16: 📲 FCM + Android系统 → PROXY
      {
        "rule_set": ["fcm", "Android"],
        "outbound": "PROXY"
      },

      // 规则17: 🇨🇳 Google中国站 → PROXY
      // google.cn 虽然在中国有服务器，但走代理更稳定
      {
        "domain_suffix": ["google.cn", "googleapis.cn"],
        "outbound": "PROXY"
      },

      // 规则18: 🌍 国外大厂域名 → PROXY
      {
        "domain_suffix": [
          "netflix", "spotify", "github", "steam",
          "discord", "reddit", "tiktok", "twitter",
          "facebook", "amazon", "microsoft", "apple", "paypal"
        ],
        "outbound": "PROXY"
      },

      // 规则19: 🌍 代理规则集 → PROXY
      {
        "rule_set": [
          "telegram", "telegram_ip",
          "geosite-youtube", "instagram",
          "Google", "ai", "GlobalMedia", "Proxy", "gfw"
        ],
        "outbound": "PROXY"
      },

      // 规则20: 🎛️ Clash全局模式 → PROXY
      {
        "clash_mode": "Global",
        "outbound": "PROXY"
      },

      // 规则21-23: 重复PROXY规则（冗余但无妨，第一条命中就停）
      {
        "rule_set": ["geosite-youtube", "geosite-google", "telegram"],
        "outbound": "PROXY"
      },
      {
        "rule_set": ["telegramip", "geosite-google", "proxy", "games", "ai"],
        "outbound": "PROXY"
      },
      {
        "rule_set": [
          "geosite-google", "geosite-youtube", "instagram",
          "telegram", "GlobalMedia", "gfw", "Proxy"
        ],
        "outbound": "PROXY"
      },

      // 规则24: 📱 Google/YouTube/Telegram App(正则) → PROXY
      {
        "package_name_regex": "^(com\\.google\\.android\\.(youtube|apps\\.(maps|docs|drive))|app\\.revanced\\.android\\.youtube|org\\.telegram\\.messenger(\\..*)?)$",
        "outbound": "PROXY"
      },

      // 规则25: 🏠 私有IP(192.168.x.x等) → DIRECT
      // 局域网设备、路由器等必须直连
      {
        "ip_is_private": true,
        "outbound": "DIRECT"
      },

      // 规则26: 🔗 FakeIP地址段 → PROXY
      // 所有198.18.x.x的流量都是FakeIP，必须走代理
      {
        "ip_cidr": "198.18.0.0/15",
        "outbound": "PROXY"
      },

      // 规则27: ⚙️ UDP路由选项
      // 关闭UDP域名反查、启用UDP connect模式
      {
        "action": "route-options",
        "udp_disable_domain_unmapping": true,
        "udp_connect": true
      },

      // 规则28: 🛡️ 广告/HTTPDNS规则集 → REJECT(丢弃)
      {
        "rule_set": ["Ads", "httpDNS", "DNSreject"],
        "action": "reject",
        "method": "drop"                    // drop=直接丢弃，不给任何回复
      },

      // 规则29: 🛡️ 具体追踪域名 → REJECT
      {
        "domain": [
          "beacon.qq.com",                  // QQ信标追踪
          "abyss.cyapi.cn",                 // 彩云天气追踪
          "ad.cyapi.cn",
          "gather.colorfulclouds.net"
        ],
        "action": "reject",
        "method": "drop"
      },

      // 规则30: 🚫 拒绝 STUN/QUIC/DTLS 协议
      // 防止WebRTC泄露真实IP（STUN会暴露）
      // QUIC/DTLS拒绝后App会自动回退TCP走代理
      {
        "protocol": ["stun", "quic", "dtls"],
        "action": "reject"
      },

      // 规则31: 🚫 拒绝保留/非法IP段
      // 这些IP段不应该出现在公网上，拦掉防止异常连接
      {
        "ip_cidr": [
          "0.0.0.0/8",                     // 本网络
          "10.0.0.0/8",                    // A类私有
          "127.0.0.0/8",                   // 回环
          "169.254.0.0/16",                // 链路本地
          "172.16.0.0/12",                 // B类私有
          "192.168.0.0/16",                // C类私有
          "224.0.0.0/4",                   // 组播
          "240.0.0.0/4"                    // 保留
        ],
        "action": "reject"
      },

      // 规则32: 🛡️ 广告规则集 → REJECT
      {
        "rule_set": ["geosite_adguard", "geosite-category-ads-all"],
        "action": "reject"
      },

      // 规则33: 🚫 拒绝 STUN/TURN/HTTPDNS（WebRTC泄露防护）
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          { "network": "udp", "port": [3478, 5349, 5350, 19302, 10000] },  // STUN/TURN端口
          { "domain_regex": "^stun\\..+" },     // stun.xxx 域名
          { "domain_keyword": ["stun", "turn", "httpdns"] },
          { "protocol": "stun" }
        ],
        "action": "reject"
      },

      // 规则34: 🛡️ 反欺诈规则集 → REJECT
      {
        "rule_set": "anti_fraud",
        "action": "reject"
      },

      // 规则35: 🔍 最后一步：域名解析
      // 前面都没命中的连接，先解析域名再重新匹配规则
      // 💡 比如只配了域名规则但App直接连IP，这里把IP还原成域名
      {
        "action": "resolve"
      }
    ],

