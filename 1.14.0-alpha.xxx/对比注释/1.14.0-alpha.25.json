    // ── 7.2 最终兜底路由 ──
    // 所有规则都没匹配的流量 → 交给 Final 选择器
    "final": "Final",

    // 自动检测网络接口（WiFi/移动数据切换时自动适应）
    "auto_detect_interface": true,

    // 默认域名解析器（域名→IP）
    // 💡 所有出站节点和HTTP客户端默认用它
    "default_domain_resolver": "alidns-quic"
  },

  // ┌─────────────────────────────────────────────────────────────┐
  // │ 8. 实验性功能 (experimental)                                │
  // │    缓存、Clash面板、调试                                    │
  // └─────────────────────────────────────────────────────────────┘
  "experimental": {
    // ── 缓存文件 ──
    // 把FakeIP映射和DNS缓存存到文件，重启不用重新下载
    "cache_file": {
        "enabled": true,
        "path": "cache.db",                // 缓存文件名
        "cache_id": "cinchov",             // 缓存ID（改了就清缓存）
        "store_fakeip": true,              // 保存FakeIP映射
        "store_dns": true                  // 保存DNS缓存
    },

    // ── Clash API ──
    // 提供Clash兼容的REST API，可以用yacd/metacubexd等面板管理
    "clash_api": {
        "external_controller": "127.0.0.1:9090",  // API监听地址
        "external_ui": "ui",                       // 面板文件目录
        "default_mode": "rule"                     // 默认规则模式
    },

    // ── 调试设置 ──
    "debug": {
        "gc_percent": 100,                 // Go垃圾回收百分比（默认100）
        "memory_limit": "400MB"            // 内存限制400MB
    }
  }

  // ╔══════════════════════════════════════════════════════════════╗
  // ║                      📖 小白速查表                           ║
  // ╠══════════════════════════════════════════════════════════════╣
  // ║  Q: 为什么有些网站打不开？                                   ║
  // ║  A: 切到 🔵自动-稳定 或手动选一个节点试试                     ║
  // ║                                                              ║
  // ║  Q: 为什么国内网站慢？                                       ║
  // ║  A: 检查PROXY选择器是不是误选了节点，应该是🟢自动-测速       ║
  // ║     国内网站走DIRECT直连，不应该慢                            ║
  // ║                                                              ║
  // ║  Q: 为什么日志文件很大？                                     ║
  // ║  A: 把 log.level 改成 "error" 就只记录错误                   ║
  // ║                                                              ║
  // ║  Q: 怎么切换节点？                                           ║
  // ║  A: 打开Clash面板(yacd) → 点PROXY → 选节点                  ║
  // ║     或者直接在配置里改 PROXY.default                         ║
  // ║                                                              ║
  // ║  Q: pkg02和pkg04为什么不能连？                               ║
  // ║  A: 它们的 server 是空的(未配置)，等机场更新                  ║
  // ║                                                              ║
  // ║  Q: 会不会泄露DNS？                                          ║
  // ║  A: 不会。所有DNS查询被劫持到内部：                           ║
  // ║     国内域名 → DoH加密 + DIRECT(快)                          ║
  // ║     国外域名 → DoH/DoT加密 + PROXY(安全)                     ║
  // ║     853端口DoT → REJECT(强制回退53)                          ║
  // ╚══════════════════════════════════════════════════════════════╝
}
