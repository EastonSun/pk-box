      "udp_over_tcp": false,       // 不使用UDP over TCP（因为QUIC原生支持UDP）
      "quic": true,                // 启用QUIC传输（使用QUIC协议替代TCP/HTTP2）
      "quic_congestion_control": "bbr", // QUIC拥塞控制：BBR算法
      "tls": {
        "enabled": true,
        "server_name": "addons.mozilla.org",
        "certificate": [           // 服务器证书（PEM格式，占位符）
