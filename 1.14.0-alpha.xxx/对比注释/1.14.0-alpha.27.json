    },

    // ▸ 节点 pkpk04：Trojan协议
    // Trojan模拟HTTPS流量，服务器伪装成HTTPS网站
    {
      "type": "trojan",            // 协议：Trojan（伪装成HTTPS的代理协议）
      "tag": "pkpk04",
      "connect_timeout": "5s",
