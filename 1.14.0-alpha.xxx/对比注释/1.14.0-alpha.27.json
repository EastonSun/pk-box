    // ▸ 节点 pkg01：VLESS + h2mux多路复用 + Brutal拥塞控制 + Reality
    // h2mux（HTTP/2多路复用）：在一个TCP连接上并发多个流，减少连接建立开销
    // Brutal：激进的带宽占用模式，适合高带宽场景
    {
      "type": "vless",
      "tag": "pkg01",
      "connect_timeout": "5s",
      "tcp_fast_open": true,
      "server": "节点域名",
      "server_port": 端口,
      "uuid": "uuid",
      "flow": "xtls-rprx-vision",  // XTLS-Vision流控
      "tls": {
        "enabled": true,
        "server_name": "addons.mozilla.org",
        "utls": {
          "enabled": true,
          "fingerprint": "firefox" // 模拟Firefox浏览器指纹（与pkpk01的chrome不同，增加多样性）
        },
        "reality": {
          "enabled": true,
          "public_key": "密钥"
        }
      },
      "multiplex": {               // 多路复用配置
        "protocol": "h2mux",       // 多路复用协议：h2mux（HTTP/2多路复用）
        "max_connections": 8,      // 最大连接数：8个并发TCP连接
        "min_streams": 16,         // 最小流数：每个连接保持至少16个流
        "brutal": {                // Brutal拥塞控制（激进占用带宽）
          "up_mbps": 1000,         // 声明上行：1000 Mbps（尽可能利用带宽）
          "down_mbps": 1000        // 声明下行：1000 Mbps
                                    // 注意：Brutal会尽力占满声明的带宽，
                                    //       如果实际带宽不足会导致丢包，谨慎设置
        }
      }
    },

    // ▸ 节点 pkg02：TUIC v5协议
    // TUIC（Tiny UDP-based Inefficient Congestion Control）
    // 基于QUIC的代理协议，UDP性能优异，适合实时流量
    {
      "type": "tuic",              // 协议：TUIC v5
      "tag": "pkg02",
      "server": "节点域名",
      "server_port": 端口,
      "uuid": "uuid",              // 用户UUID（TUIC使用UUID认证）
      "password": "密码",          // 额外密码验证
      "congestion_control": "bbr", // 拥塞控制算法：BBR（Google开发，带宽利用率高）
      "udp_relay_mode": "native",  // UDP转发模式：native（原生UDP，性能最好）
                                    // 另一选项是"quic"（把UDP包封装在QUIC流中）
      "heartbeat": "10s",          // 心跳间隔：10秒发一次心跳包（保持连接活跃）
      "tls": {
        "enabled": true,
        "server_name": "addons.mozilla.org",
        "alpn": "h3",              // ALPN：h3（伪装为HTTP/3）
        "certificate_public_key_sha256": "密钥" // 证书指纹固定
      },
      "stream_receive_window": 0,  // QUIC流窗口
      "connection_receive_window": 0  // QUIC连接窗口
    },

    // ▸ 节点 pkg03：Shadowsocks + h2mux多路复用 + Brutal
    {
      "type": "shadowsocks",
      "tag": "pkg03",
      "connect_timeout": "5s",
      "server": "节点域名",
      "server_port": 端口,
      "method": "2022-blake3-aes-128-gcm", // 加密方式
      "password": "密码",
      "multiplex": {               // 多路复用（Shadowsocks本不支持，这是扩展功能）
        "enabled": true,
        "protocol": "h2mux",       // 使用h2mux多路复用
        "max_connections": 8,
        "min_streams": 16,
        "padding": true,           // 启用随机填充：在数据包中添加随机字节
                                    // 目的：混淆流量特征，使流量统计分析更难识别
        "brutal": {
          "up_mbps": 1000,
          "down_mbps": 1000
        }
      }
    },

    // ▸ 节点 pkg04：Trojan + h2mux多路复用 + uTLS + Brutal
    {
      "type": "trojan",
      "tag": "pkg04",
      "connect_timeout": "5s",
      "tcp_fast_open": true,
      "server": "节点域名",
      "server_port": 端口,
      "password": "密码",
      "tls": {
        "enabled": true,
        "server_name": "addons.mozilla.org",
        "certificate_public_key_sha256": "密钥",
        "utls": {
          "enabled": true,
          "fingerprint": "firefox" // Firefox指纹
        }
      },
      "multiplex": {               // 多路复用
        "enabled": true,
        "protocol": "h2mux",
        "max_connections": 8,
        "min_streams": 16,
        "padding": true,
        "brutal": {
          "up_mbps": 1000,
          "down_mbps": 1000
        }
      }
    },

    // ▸ 节点 pkg05：VLESS + HTTP传输层 + Reality
    // HTTP传输：将代理流量包装在普通HTTP请求中
    {
      "type": "vless",
      "tag": "pkg05",
      "connect_timeout": "5s",
      "tcp_fast_open": true,
      "server": "节点域名",
