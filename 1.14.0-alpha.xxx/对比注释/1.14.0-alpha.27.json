// ============================================================
// 文件说明：sing-box 代理工具完整配置文件（含逐行注释）
// 工具：sing-box —— 一款支持多协议的现代网络代理工具
// 官网：https://sing-box.sagernet.org
// 注意：标准JSON不支持注释，本文件为"带注释的说明版"，
//       实际使用时需删除所有 // 开头的注释行才能被sing-box解析
// ============================================================

{

  // ══════════════════════════════════════════════
  // 【第一节】log —— 日志配置
  // 控制程序运行时输出的日志信息，方便调试排查问题
  // ══════════════════════════════════════════════

  "log": {
    "level": "trace",       // 日志级别：trace（最详细）> debug > info > warn > error
                             // trace 会打印所有网络请求细节，调试用；正式使用建议改为 "warn" 或 "info"
    "timestamp": true        // 是否在每条日志前面加上时间戳，true=加，便于对照时间排查问题
  },

  // ══════════════════════════════════════════════
  // 【第二节】dns —— DNS解析配置（最核心、最复杂的部分）
  // DNS负责把域名（如 google.com）翻译成IP地址
  // 本配置使用分流策略：国内域名走国内DNS，国外域名走代理DNS，广告域名直接拦截
  // ══════════════════════════════════════════════

  "dns": {

    // ────────────────────────────────────────────
    // dns.servers —— 定义所有可用的DNS服务器
    // 每个server有一个唯一tag，后面rules里通过tag来引用
    // ────────────────────────────────────────────

    "servers": [

      // ▸ 第1个DNS服务器：hosts静态映射表
      // 作用：提前硬编码DNS服务器本身的IP，防止查询DNS时陷入"先有鸡还是先有蛋"的死循环
      // 疑问：为什么DNS服务器自己也需要DNS解析？
      // 回答：比如 dns.google 这个域名需要先解析成IP才能连上它，
      //       如果没有这张表，就会循环依赖，永远无法完成首次解析
      {
        "type": "hosts",           // 类型：本地hosts映射，类似系统的 /etc/hosts 文件
        "tag": "hosts_fix",        // 标签名，其他server通过 "domain_resolver": "hosts_fix" 来引用它
        "predefined": {            // 预定义的域名→IP映射表（直接写死，不走网络查询）

          "dns.alidns.com": [      // 阿里DNS的域名（DoH/DoQ服务）
            "223.5.5.5",           // 阿里DNS主IP（俗称"阿里公共DNS"）
            "223.6.6.6"            // 阿里DNS备用IP
          ],

          "dns.adguard.com": [     // AdGuard DNS的域名（带广告过滤功能的DNS）
            "94.140.14.15",        // AdGuard DNS主IP
            "94.140.15.16"         // AdGuard DNS备用IP
          ],

          "doh.pub": [             // DNSPod（腾讯）的DoH服务域名
            "1.12.12.21",          // DNSPod主IP
            "120.53.53.53"         // DNSPod备用IP
          ],

          "dns.google": [          // Google DNS的DoH域名
            "8.8.8.8",             // Google DNS主IP（全球最知名的公共DNS）
            "8.8.4.4"              // Google DNS备用IP
          ],

          "cloudflare-dns.com": [  // Cloudflare DNS的DoH域名（1.1.1.1服务）
            "104.16.248.249",      // Cloudflare DOH服务IP之一
            "104.16.249.249"       // Cloudflare DOH服务IP之二
          ],

          "dns.cloudflare.com": [  // Cloudflare DNS的另一个域名（与上面指向同一服务）
            "104.16.248.249",      // 同上
            "104.16.249.249"       // 同上
          ],

          "dns.quad9.net": [       // Quad9 DNS的DoH域名（注重安全，会屏蔽恶意域名）
            "9.9.9.9",             // Quad9主IP
            "149.112.112.112"      // Quad9备用IP
          ],

          "mtalk.google.com": [    // Google消息推送服务（FCM/GCM）的域名
            "142.250.107.188",     // mtalk服务IP之一
            "142.251.170.188",     // mtalk服务IP之二
            "108.177.125.188"      // mtalk服务IP之三（多个IP做负载均衡）
          ],

          "alt1-mtalk.google.com": "74.125.200.188"
          // Google备用消息推送服务器alt1的IP（注意此处是字符串而非数组，只有一个IP）
        }
      },

      // ▸ 第2个DNS服务器：阿里DNS（DNS-over-QUIC协议）
      // DoQ（DNS over QUIC）：基于QUIC协议的加密DNS，速度快、延迟低
      // 走DIRECT直连，用于解析国内域名
      {
        "type": "quic",            // 协议类型：DNS-over-QUIC（加密传输，端口853/UDP）
        "tag": "alidns-quic",      // 标签：后面rules里会用这个名字引用它
        "detour": "DIRECT",        // 出口通道：DIRECT=直连，不走代理（国内DNS直连更快）
        "domain_resolver": "hosts_fix", // 解析服务器域名时使用hosts_fix（避免循环依赖）
        "server": "dns.alidns.com" // DNS服务器地址（通过hosts_fix解析为223.5.5.5等）
      },

      // ▸ 第3个DNS服务器：DNSPod（腾讯）DoH
      // DoH（DNS over HTTPS）：把DNS查询包装在HTTPS请求中，防止DNS污染和监听
      // 走DIRECT直连，用于解析国内/私有域名
      {
        "type": "https",           // 协议类型：DNS-over-HTTPS（加密传输，端口443/TCP）
        "tag": "dnspub-doh",       // 标签名
        "detour": "DIRECT",        // 直连，不走代理
        "domain_resolver": "hosts_fix", // 用hosts_fix解析服务器域名
        "server": "doh.pub"        // DNSPod的DoH服务地址
      },

      // ▸ 第4个DNS服务器：Google DNS（DoH协议）
      // 走代理，专门用于查询需要代理访问的谷歌相关域名
      {
        "type": "https",           // 协议：DoH
        "tag": "ggdns",            // 标签名（gg = Google）
        "detour": "PROXY",         // 出口：走代理（谷歌DNS在国内无法直连）
        "domain_resolver": "hosts_fix", // 用hosts_fix解析服务器域名
        "server": "dns.google"     // Google DoH服务地址
      },

      // ▸ 第5个DNS服务器：AdGuard自建DNS（普通UDP协议）
      // 这里用的是一个自建的AdGuard DNS实例（非官方公共IP）
      // 走代理，是整个DNS配置的"兜底"服务器（final字段指向它）
      {
        "type": "udp",             // 协议：普通UDP DNS（传统DNS，端口53，明文，速度快）
        "tag": "adguard-dns",      // 标签名
        "detour": "PROXY",         // 走代理
        "server": "107.172.252.185", // 自建AdGuard DNS服务器的IP（非公共IP，是私人部署）
        "server_port": 53          // DNS服务端口（标准DNS端口为53）
      },

      // ▸ 第6个DNS服务器：Quad9 DoH
      // Quad9 以安全著称，会自动屏蔽已知恶意域名
      // 走代理访问
      {
        "type": "https",           // 协议：DoH
        "tag": "quad9-doh",        // 标签名
        "detour": "PROXY",         // 走代理
        "domain_resolver": "hosts_fix", // 用hosts_fix解析服务器域名
        "server": "dns.quad9.net"  // Quad9 DoH服务地址
      },

      // ▸ 第7个DNS服务器：FakeIP（虚假IP）
      // 重要机制说明：FakeIP不是真正的DNS服务器，而是一种加速技术
      // 工作原理：对每个域名返回一个虚假的IP（如198.18.x.x），
      //           当数据包发到这个假IP时，sing-box截获它，用原始域名通过代理建立连接
      // 优点：极大减少DNS查询延迟，因为不需要等待真实DNS解析完成再建立连接
      // 疑问：为什么要用假IP？直接用域名连接不行吗？
      // 回答：某些底层网络协议必须先有IP才能建立连接，FakeIP是一个巧妙的折中方案
      {
        "type": "fakeip",          // 类型：FakeIP虚假IP分配器
        "tag": "fakeip",           // 标签名
        "inet4_range": "198.18.0.0/15",  // IPv4的FakeIP地址段（198.18.0.0 ~ 198.19.255.255，共131072个地址）
        "inet6_range": "fc00::/18"       // IPv6的FakeIP地址段（fc00:: 开头的私有地址段）
      }

    ], // servers数组结束

    // ────────────────────────────────────────────
    // dns.rules —— DNS分流规则（从上到下依次匹配，匹配到就停止）
    // 决定哪些域名用哪个DNS服务器来解析
    // ────────────────────────────────────────────

    "rules": [

      // ▸ 规则1：游戏平台域名 → FakeIP
      // Steam、Epic等游戏平台的CDN内容分发域名走FakeIP
      // 目的：让游戏下载/更新走代理并通过FakeIP加速连接建立
      {
        "domain_suffix": [         // 匹配域名后缀（即该域名或其所有子域名）
          "steamcontent.com",      // Steam内容分发网络CDN
          "steamserver.net",       // Steam服务器
          "epicgames.com",         // Epic Games游戏平台
          "gog.com",               // GOG游戏平台（以无DRM著称）
          "battle.net",            // 暴雪战网平台
          "blizzard.com",          // 暴雪娱乐官网
          "origin.com",            // EA Origin游戏平台（现更名EA App）
          "ea.com",                // EA（美国艺电）官网
          "ubisoft.com",           // 育碧游戏官网
          "rockstargames.com"      // Rockstar Games（GTA等游戏开发商）
        ],
        "server": "fakeip"         // 对以上域名分配FakeIP
      },

      // ▸ 规则2：Google Play相关域名 → Google DNS（真实IP）
      // 疑问：为什么Play Store单独用ggdns而不是fakeip？
      // 回答：Google Play应用验证、下载完整性校验等机制需要真实IP，
      //       FakeIP可能导致应用安装失败或更新异常
      {
        "query_type": [            // 限制查询类型（只有A/AAAA查询才匹配此规则）
          "A",                     // A记录：IPv4地址查询
          "AAAA"                   // AAAA记录：IPv6地址查询
        ],
        "domain_suffix": [         // 匹配以下Google Play相关域名
          "android.clients.google.com",   // Android设备注册/认证服务
          "dl.google.com",                // Google下载服务器
          "dl.l.google.com",             // Google下载服务器（子域）
          "play.google.com",             // Google Play商店主域名
          "play.googleapis.com",         // Google Play API接口
          "play-fe.googleapis.com",      // Google Play前端API
          "play-lh.googleusercontent.com",         // Play商店应用图标/截图CDN
          "play-apps-features.googleusercontent.com", // Play商店功能特性图片CDN
          "playstoregatewayadapter-pa.googleapis.com",      // Play商店网关适配器
          "prod-lt-playstoregatewayadapter-pa.googleapis.com", // Play商店网关（生产环境）
          "gvt1.com",              // Google视频测速/传输域名
          "gvt2.com",              // Google传输服务备用域名
          "gvt3.com"               // Google传输服务备用域名
        ],
        "server": "ggdns"          // 用Google自己的DNS解析（走代理），获取真实IP
      },

      // ▸ 规则3：主要被代理的国外社交/媒体平台 → FakeIP
      // Google全系、Twitter、Facebook、Instagram等通过FakeIP加速
      {
        "query_type": [            // 同样只匹配A/AAAA类型查询
          "A",
          "AAAA"
        ],
        "domain_suffix": [         // 匹配以下域名后缀
          "play.google.com",       // Google Play（此处与规则2重叠，但规则2优先匹配）
          "play.googleapis.com",   // Google Play API
          "android.clients.google.com",   // Android客户端服务
          "android.googleapis.com",        // Android Google API
          "dl.google.com",         // Google下载
          "dl.l.google.com",      // Google下载子域
          "gvt1.com",              // Google传输
          "gvt2.com",              // Google传输
          "gvt3.com",              // Google传输
          "services.googleapis.com",       // Google各类服务API
          "googleapis.com",        // Google API总域名
          "gstatic.com",           // Google静态资源CDN（字体、图标等）
          "google.com",            // Google主域名
          "google.com.hk",         // Google香港域名
          "ggpht.com",             // Google Photo相关CDN
          "googleusercontent.com", // Google用户上传内容存储
          "youtube.com",           // YouTube视频平台
          "ytimg.com",             // YouTube图片/缩略图CDN
          "googlevideo.com",       // YouTube视频流传输CDN
          "app-measurement.com",   // Google Firebase应用分析
          "firebaselogging.googleapis.com",    // Firebase日志API
          "firebaselogging-pa.googleapis.com", // Firebase日志（私有API）
          "twitter.com",           // Twitter/X社交媒体
          "twimg.com",             // Twitter图片/媒体CDN
          "facebook.com",          // Facebook社交网络
          "fbcdn.net",             // Facebook内容分发网络CDN
          "instagram.com",         // Instagram图片社交
          "cdninstagram.com"       // Instagram内容CDN
        ],
        "server": "fakeip"         // 对以上域名分配FakeIP加速连接
      },

      // ▸ 规则4：通过规则集批量匹配需要代理的域名 → FakeIP
      // 规则集是外部下载的SRS文件，包含大量域名，比手动列举更全面
      {
        "rule_set": [              // 引用已定义的规则集（在route.rule_set中定义）
          "geosite-google",        // Google全系服务域名集合
          "geosite-youtube",       // YouTube相关域名集合
          "instagram",             // Instagram域名集合
          "telegram",              // Telegram即时通讯域名集合
          "Proxy",                 // 通用代理域名集合（非中国大陆域名）
          "gfw",                   // GFW封锁域名集合（被防火长城封锁的域名）
          "ai",                    // AI服务域名集合（ChatGPT、Claude等）
          "games",                 // 游戏平台域名集合
          "GlobalMedia"            // 全球流媒体平台域名集合（Netflix、Disney+等）
        ],
        "server": "fakeip"         // 全部走FakeIP
      },

      // ▸ 规则5：Steam局域网缓存服务 → 阿里DNS直连
      // lancache是局域网游戏缓存服务，允许局域网内多台电脑共享游戏下载缓存
      // 必须直连解析，否则缓存服务无法正常工作
      {
        "domain_suffix": "lancache.steamcontent.com", // Steam局域网缓存专用域名
        "server": "alidns-quic"    // 走阿里DNS直连解析（获取局域网缓存服务器的真实IP）
      },

      // ▸ 规则6：微软网络连通性测试域名 → 阿里DNS直连
      // Windows系统用这两个域名检测网络是否连接到互联网
      // 若走FakeIP会导致Windows任务栏网络图标显示"无Internet访问"
      {
        "domain_suffix": [
          "msftncsi.com",          // Microsoft网络连通性状态指示器（NCSI）
          "msftconnecttest.com"    // 微软网络连接测试域名
        ],
        "server": "alidns-quic"    // 直连解析，确保Windows网络状态正确显示
      },

      // ▸ 规则7：私有网络域名 → DNSPod直连
      // private规则集包含内网/局域网相关域名，直连解析
      {
        "rule_set": "private",     // 私有地址规则集（192.168.x.x、10.x.x.x等内网地址对应的域名）
        "server": "dnspub-doh"     // 走DNSPod DoH直连解析
      },

      // ▸ 规则8：中国大陆域名 → DNSPod直连
      {
        "rule_set": "cn",          // 中国大陆域名规则集（包含各大中国网站域名）
        "server": "dnspub-doh"     // 走国内DNS（DNSPod）直连解析，速度快
      },

      // ▸ 规则9：.cn和.com.cn顶级域名 → 阿里DNS直连
      // 兜底规则，确保所有.cn域名都走国内DNS
      {
        "domain_suffix": [
          ".cn",                   // 中国顶级域名（如 baidu.cn）
          ".com.cn"                // 中国商业二级域名（如 163.com.cn）
        ],
        "server": "alidns-quic"    // 走阿里DNS直连解析
      },

      // ▸ 规则10：FakeIP过滤规则集 → 阿里DNS直连
      // 某些域名不适合走FakeIP（如需要真实IP才能正常工作的服务），走直连DNS
      {
        "rule_set": "Filter",      // fakeip-filter规则集：不应该走FakeIP的域名列表
        "server": "alidns-quic"    // 这些域名走直连DNS解析，获取真实IP
      },

      // ▸ 规则11：广告/DNS污染域名 → 返回空响应（屏蔽）
      // action=predefined + rcode=NOERROR：返回一个"成功但空结果"的DNS响应
      // 效果：域名被屏蔽，但不会触发"域名不存在"错误（避免部分应用报错）
      {
        "rule_set": [
          "httpDNS",               // HTTP DNS规则集：阻止应用绕过系统DNS直接发HTTP查询
          "DNSreject",             // DNS拒绝规则集：AdGuard DNS过滤规则
          "Ads"                    // 广告域名规则集
        ],
        "action": "predefined",    // 动作：返回预定义响应（不转发给真实DNS服务器）
        "rcode": "NOERROR"         // 返回码：NOERROR（假装解析成功，但不返回IP，静默屏蔽）
      },

      // ▸ 规则12：拒绝所有IPv6 DNS查询
      // 疑问：为什么要拒绝IPv6查询？
      // 回答：很多代理节点或网络环境对IPv6支持不完善，
      //       禁用AAAA查询可以强制走IPv4，减少连接失败的概率
      {
        "ip_version": 6,           // 匹配IPv6的DNS查询
        "action": "reject"         // 直接拒绝，不解析
      },

      // ▸ 规则13：拒绝特定类型的DNS查询
      // SVCB/HTTPS/PTR查询在代理场景下容易造成泄漏或异常
      {
        "query_type": [
          "SVCB",                  // SVCB记录：服务绑定记录，包含HTTPS连接参数（较新的DNS类型）
          "HTTPS",                 // HTTPS记录：包含HTTP/3(QUIC)等连接参数，可能泄露真实IP
          "PTR"                    // PTR记录：反向DNS查询（IP→域名），通常无需代理
        ],
        "action": "reject"         // 拒绝这些类型的查询
      },

      // ▸ 规则14：AdGuard广告过滤规则集 → 拒绝解析（屏蔽广告域名）
      {
        "rule_set": [
          "geosite_adguard",               // AdGuard广告域名过滤规则
          "geosite-category-ads-all"        // sing-geosite广告分类规则集
        ],
        "action": "reject"         // 拒绝解析广告域名（DNS层面屏蔽广告）
      },

      // ▸ 规则15：拒绝特定Google追踪/信标域名
      // beacons.gvt2.com系列是Google用于收集遥测数据的域名
      {
        "domain_suffix": [
          "beacons.gvt2.com",      // Google遥测信标域名1
          "beacons2.gvt2.com",     // Google遥测信标域名2
          "beacons3.gvt2.com"      // Google遥测信标域名3
        ],
        "action": "reject"         // 拒绝解析，阻止Google追踪
      },

      // ▸ 规则16：拒绝内网/本地域名解析
      // 这些域名只在局域网内有意义，不应该发到公网DNS服务器
      {
        "domain_suffix": [
          ".local",                // mDNS本地域名（如 macbook.local）
          ".lan",                  // 局域网常用域名（路由器等设备）
          "local",                 // 本地（无后缀版本）
          "lan",                   // 局域网（无后缀版本）
          "home",                  // 家庭网络常用域名（如路由器后台）
          "internal",              // 企业内网常用域名
          "corp"                   // 企业局域网域名（如 server.corp）
        ],
        "action": "reject"         // 拒绝向公网DNS发送这些查询（保护隐私、避免泄漏内网结构）
      },

      // ▸ 规则17：拒绝所有非A/AAAA类型的其他DNS查询
      // invert=true 表示"取反"：匹配"不是A且不是AAAA"的查询
      // 即只允许IPv4/IPv6地址查询，其他类型（MX、TXT、NS等）全部拒绝
      {
        "query_type": [
          "A",                     // IPv4地址查询（允许通过）
          "AAAA"                   // IPv6地址查询（允许通过）
        ],
        "invert": true,            // 取反！即匹配"不是A也不是AAAA"的所有其他DNS类型
        "action": "reject"         // 拒绝这些其他类型的DNS查询
      }

    ], // dns.rules结束

    "final": "adguard-dns",        // 兜底DNS：所有规则都不匹配时，最终用adguard-dns解析
                                    // 即自建的AdGuard DNS服务器（走代理访问）
    "reverse_mapping": true,        // 开启IP→域名反向映射，配合fakeip使用
                                    // 当sing-box收到FakeIP的数据包时，能找到对应的真实域名
    "strategy": "prefer_ipv4",      // IP版本策略：优先使用IPv4（兼容性更好）
    "timeout": "3s",                // DNS查询超时时间：3秒无响应则视为超时
    "cache_capacity": 256000,       // DNS缓存容量：最多缓存256000条DNS记录（减少重复查询）
    "optimistic": {                 // 乐观缓存配置
      "enabled": true,              // 启用乐观缓存：即使缓存已过期，也先返回旧结果，后台异步刷新
                                    // 优点：大幅降低DNS解析延迟，用户体验更流畅
      "timeout": "1h0m0s"           // 乐观缓存最大有效期：1小时内的过期缓存仍可使用
    }

  }, // dns节结束

  // ══════════════════════════════════════════════
  // 【第三节】ntp —— 网络时间协议配置
  // 自动同步系统时钟，确保TLS证书验证、时间敏感型协议正常工作
  // 疑问：为什么代理工具需要NTP？
  // 回答：某些协议（如Hysteria2、QUIC）对时钟精度要求很高，
  //       时钟偏差过大会导致连接失败或TLS握手失败
  // ══════════════════════════════════════════════

  "ntp": {
    "enabled": true,               // 启用NTP时钟同步
    "interval": "30m0s",           // 同步间隔：每30分钟同步一次
    "server": "ntp.aliyun.com",    // NTP服务器：阿里云NTP（国内可靠，延迟低）
    "server_port": 123,            // NTP协议标准端口：123（UDP）
    "detour": "PROXY"              // 走代理（疑问：NTP为何走代理？
                                    // 回答：可能是为了防止ISP劫持NTP请求导致时间不准）
  },

  // ══════════════════════════════════════════════
  // 【第四节】http_clients —— HTTP客户端配置
  // 用于下载规则集文件（rule_set里的.srs文件）时使用
  // ══════════════════════════════════════════════

  "http_clients": [

    // ▸ 默认HTTP客户端（直连，用于下载国内可访问的规则集）
    {
      "tag": "default",                    // 标签名，在rule_set的http_client字段引用
      "version": 2,                        // HTTP版本：HTTP/2（比HTTP/1.1更高效，支持多路复用）
      "detour": "DIRECT",                  // 出口：直连（不走代理）
      "stream_receive_window": 0,          // HTTP/2流接收窗口大小：0表示使用默认值
      "connection_receive_window": 0       // HTTP/2连接接收窗口大小：0表示使用默认值
    },

    // ▸ 代理HTTP客户端（走代理，用于下载需要代理才能访问的规则集）
    {
      "tag": "proxy",                      // 标签名
      "version": 2,                        // HTTP/2
      "detour": "PROXY",                   // 出口：走代理
      "stream_receive_window": 0,          // 默认窗口大小
      "connection_receive_window": 0       // 默认窗口大小
    }

  ],

  // ══════════════════════════════════════════════
  // 【第五节】inbounds —— 入站配置
  // 定义sing-box监听哪些端口/接口来接收流量
  // ══════════════════════════════════════════════

  "inbounds": [

    // ▸ 入站1：TUN虚拟网卡（最重要的入站，实现透明代理）
    // TUN是一个虚拟网络设备，sing-box通过它接管系统所有网络流量
    // 疑问：TUN和普通代理有什么区别？
    // 回答：普通代理需要应用主动配置代理地址；TUN在系统层面接管所有流量，
    //       所有应用（包括不支持代理的应用）的流量都会被自动接管
    {
      "type": "tun",               // 类型：TUN虚拟网卡
      "tag": "tun-in",             // 标签名
      "mtu": 1500,                 // 最大传输单元：1500字节（以太网标准MTU，适合大多数网络环境）
      "address": [                 // TUN接口的IP地址（分配给这个虚拟网卡的地址）
        "10.8.0.1/24",             // IPv4地址：10.8.0.1，子网掩码/24（10.8.0.0 ~ 10.8.0.255）
        "fdfe:dcba:9876::1/126"    // IPv6地址：/126子网（只有4个地址：::0, ::1, ::2, ::3）
      ],
      "dns_mode": "hijack",        // DNS模式：劫持（自动拦截所有发往53端口的DNS请求）
      "dns_address": [             // 被劫持后，DNS请求重定向到这些地址（虚拟DNS服务器地址）
        "10.8.0.2",                // IPv4 DNS劫持地址（TUN子网内的地址，sing-box内部处理）
        "fdfe:dcba:9876::2"        // IPv6 DNS劫持地址
      ],
      "auto_route": true,          // 自动路由：自动添加系统路由规则，将流量导入TUN
      "route_address_set": [       // 精确路由：只将这些地址集的IP路由到TUN（其余走直连）
        "cnip",                    // 中国大陆IP地址集：这些IP走直连（绕过TUN）
        "private"                  // 私有IP地址集：内网地址走直连
                                   // 疑问：既然route_address_set是例外，那非中国IP默认都进TUN吗？
                                   // 回答：是的，除了cnip和private里的IP，其余都通过TUN处理
      ],
      "stack": "system"            // 网络栈：使用系统原生TCP/IP栈（稳定性好）
                                    // 另一选项是"gvisor"（用户态栈，兼容性更好但性能略低）
    },

    // ▸ 入站2：混合代理（同时支持HTTP和SOCKS5协议）
    // 最常用的本地代理入口，浏览器/应用可以配置使用
    {
      "type": "mixed",             // 类型：混合代理（同时接受HTTP CONNECT和SOCKS5连接）
      "tag": "mixed-in",           // 标签名
      "listen": "127.0.0.1",       // 监听地址：127.0.0.1=仅本机可访问（安全）
      "listen_port": 7890          // 监听端口：7890（Clash系列工具的传统默认端口）
    },

    // ▸ 入站3：纯HTTP代理
    {
      "type": "http",              // 类型：HTTP代理（只支持HTTP CONNECT）
      "tag": "http-in",            // 标签名
      "listen": "127.0.0.1",       // 仅本机访问
      "listen_port": 7891          // 端口：7891
    },

    // ▸ 入站4：SOCKS5代理
    {
      "type": "socks",             // 类型：SOCKS5代理（支持TCP和UDP，更通用）
      "tag": "socks-in",           // 标签名
      "listen": "127.0.0.1",       // 仅本机访问
      "listen_port": 7892          // 端口：7892
    },

    // ▸ 入站5：重定向代理（iptables/nftables透明代理用）
    // 主要用于Linux系统上配合iptables实现透明代理
    {
      "type": "redirect",          // 类型：重定向（接受iptables REDIRECT转发来的TCP流量）
      "tag": "redirect-in",        // 标签名
      "listen": "127.0.0.1",       // 本机监听
      "listen_port": 7893          // 端口：7893
    }

  ], // inbounds结束

  // ══════════════════════════════════════════════
  // 【第六节】outbounds —— 出站配置
  // 定义流量最终通过哪个通道出去（直连/代理/屏蔽）
  // ══════════════════════════════════════════════

  "outbounds": [

    // ▸ 出站1：DIRECT 直连
    // 流量不经过任何代理，直接发送到目标服务器
    {
      "type": "direct",            // 类型：直连
      "tag": "DIRECT",             // 标签名（大写，表示这是重要的基础出站）
      "domain_resolver": "alidns-quic"  // 直连时使用阿里DNS解析域名
    },

    // ▸ 出站2：PROXY 手动选择器
    // 用户可以手动选择使用哪个代理节点，默认使用自动测速
    {
      "type": "selector",          // 类型：选择器（手动或自动选择出站）
      "tag": "PROXY",              // 标签名
      "outbounds": [               // 可供选择的出站列表
        "🟢 自动-测速",             // 自动测速选择最快节点
        "🔵 自动-稳定",             // 自动选择最稳定节点
        "pkpk01",                  // 个人节点01（VLESS+XTLS-Vision+Reality）
        "pkpk02",                  // 个人节点02（Hysteria2协议）
        "pkpk03",                  // 个人节点03（VLESS+gRPC+Reality）
        "pkpk04",                  // 个人节点04（Trojan协议）
        "pkpk05",                  // 个人节点05（Shadowsocks协议）
        "pkg01",                   // 共享节点01（VLESS+h2mux多路复用）
        "pkg02",                   // 共享节点02（TUIC协议）
        "pkg03",                   // 共享节点03（Shadowsocks+h2mux）
        "pkg04",                   // 共享节点04（Trojan+h2mux）
        "pkg05",                   // 共享节点05（VLESS+HTTP传输）
        "pkg06",                   // 共享节点06（VLESS+gRPC传输）
        "pkg07",                   // 共享节点07（AnyTLS协议）
        "pkg08",                   // 共享节点08（Naive+TCP）
        "pkg09",                   // 共享节点09（Naive+QUIC）
        "DIRECT"                   // 也可选择直连（某些情况下临时绕过所有代理）
      ],
      "default": "🟢 自动-测速"    // 默认选择：自动测速（优先最低延迟节点）
    },

    // ▸ 出站3：🟢 自动-测速（URLTest延迟优先）
    // 定期测试所有节点的延迟，自动选择延迟最低的节点
    {
      "type": "urltest",           // 类型：URL测试（自动测速选优）
      "tag": "🟢 自动-测速",       // 标签名
      "outbounds": [               // 参与测速的节点列表
        "pkpk01", "pkpk02", "pkpk03", "pkpk04", "pkpk05",  // 个人节点
        "pkg01", "pkg02", "pkg03", "pkg04", "pkg05", "pkg06", "pkg07", "pkg08", "pkg09"  // 共享节点
      ],
      "url": "http://www.gstatic.com/generate_204", // 测速URL：访问Google的204响应页（无内容快速返回）
      "interval": "10m0s",         // 测速间隔：每10分钟重新测速一次
      "tolerance": 100,            // 容差：当前节点延迟 vs 最优节点延迟相差超过100ms才切换
                                    // （避免频繁切换）
      "idle_timeout": "30m0s"      // 空闲超时：30分钟没有流量就暂停测速（节省资源）
    },

    // ▸ 出站4：🔵 自动-稳定（URLTest稳定优先）
    // 与测速版类似，但容差更小（30ms）、间隔更长（15分钟），更注重稳定性
    {
      "type": "urltest",           // 类型：URL测试
      "tag": "🔵 自动-稳定",       // 标签名
      "outbounds": [               // 参与测试的节点（与测速版相同）
        "pkpk01", "pkpk02", "pkpk03", "pkpk04", "pkpk05",
        "pkg01", "pkg02", "pkg03", "pkg04", "pkg05", "pkg06", "pkg07", "pkg08", "pkg09"
      ],
      "url": "http://www.gstatic.com/generate_204", // 同样用Google 204作为测速URL
      "interval": "15m0s",         // 测速间隔：15分钟（更长，减少测速频率）
      "tolerance": 30,             // 容差：30ms（更严格，只有延迟改善超过30ms才切换节点）
      "idle_timeout": "1h0m0s"     // 空闲超时：1小时无流量则暂停
    },

    // ▸ 出站5：🟣 QUIC-UDP选择器
    // 专门用于QUIC/UDP流量的节点选择器，选择支持UDP的节点
    // 疑问：为什么QUIC流量需要单独的节点组？
    // 回答：QUIC协议基于UDP，并非所有代理节点都支持UDP转发，
    //       这里专门筛选出支持UDP/QUIC的节点
    {
      "type": "selector",          // 类型：手动选择器
      "tag": "🟣 QUIC-UDP",        // 标签名
      "outbounds": [
        "pkpk02",                  // pkpk02：Hysteria2（原生UDP协议，天然支持QUIC转发）
        "pkg02",                   // pkg02：TUIC（基于QUIC的代理，UDP支持最好）
        "pkg09"                    // pkg09：Naive+QUIC（QUIC传输）
      ],
      "default": "pkpk02"          // 默认：pkpk02（Hysteria2性能最强）
    },

    // ▸ 出站6：GLOBAL全局选择器
    // 当路由规则进入"Global"模式时使用
    {
      "type": "selector",          // 类型：选择器
      "tag": "GLOBAL",             // 标签名
      "outbounds": ["PROXY", "DIRECT"], // 可选：走代理或直连
      "default": "PROXY"           // 默认走代理
    },

    // ▸ 出站7：CN中国大陆选择器
    // 当流量被判定为中国大陆时使用
    {
      "type": "selector",          // 类型：选择器
      "tag": "CN",                 // 标签名
      "outbounds": ["DIRECT", "PROXY"], // 可选：直连或代理
      "default": "DIRECT"          // 默认直连（大陆流量走直连最快）
    },

    // ▸ 出站8：Final最终兜底选择器
    // 所有路由规则都不匹配时，流量走这个出站
    {
      "type": "selector",          // 类型：选择器
      "tag": "Final",              // 标签名（DNS的final也指向这个）
      "outbounds": ["PROXY", "DIRECT", "REJECT-DROP"], // 三个选项
      "default": "PROXY"           // 默认走代理（未知流量宁可走代理也不直连，保护隐私）
    },

    // ▸ 出站9：REJECT-DROP 丢弃
    // 直接丢弃匹配的流量，不发送任何响应
    {
      "type": "block",             // 类型：屏蔽（丢弃所有流量，不回应任何内容）
      "tag": "REJECT-DROP"         // 标签名（通常用于广告屏蔽）
    },

    // ══════════════════════════════════════════════
    // 以下是实际的代理节点出站配置
    // 格式说明：节点名以pk开头=个人节点，以g开头=共享/公用节点
    // ══════════════════════════════════════════════

    // ▸ 节点 pkpk01：VLESS + XTLS-rprx-vision + Reality
    // 最高隐蔽性的协议组合：
    // - VLESS：轻量协议，无加密开销
    // - XTLS-Vision：直接转发TLS流量，无需再套一层TLS（减少特征）
    // - Reality：伪装成合法网站的TLS，无需自签证书
    {
      "type": "vless",             // 协议：VLESS（轻量级代理协议）
      "tag": "pkpk01",             // 节点标签名
      "connect_timeout": "5s",     // 连接超时：5秒
      "tcp_fast_open": true,       // TCP快速打开：减少TCP握手时间（3次握手变1次）
      "tcp_keep_alive": "30s",     // TCP保活间隔：30秒发一次保活包（防止连接被NAT设备断开）
      "tcp_keep_alive_interval": "5s", // 保活包发送间隔：5秒
      "udp_fragment": true,        // UDP分片：将大UDP包分片发送（绕过某些MTU限制）
      "server": "节点域名",         // 服务器地址（占位符，实际使用时替换为真实域名/IP）
      "server_port": 端口,          // 服务器端口（占位符，替换为实际端口号）
      "uuid": "uuid",              // 用户身份标识（占位符，替换为实际UUID）
      "flow": "xtls-rprx-vision",  // 流控：XTLS-Vision（直接转发TLS内层流量，减少双重加密）
      "tls": {                     // TLS传输层安全配置
        "enabled": true,           // 启用TLS
        "server_name": "addons.mozilla.org", // SNI伪装：伪装成Mozilla附加组件网站（高可信度域名）
        "utls": {                  // uTLS指纹模拟配置
          "enabled": true,         // 启用uTLS（模拟真实浏览器的TLS指纹，防止特征识别）
          "fingerprint": "chrome"  // 指纹：模拟Chrome浏览器的TLS握手特征
        },
        "reality": {               // Reality协议配置（X-Ray团队开发的新型隐蔽技术）
          "enabled": true,         // 启用Reality
          "public_key": "密钥"     // Reality公钥（占位符，替换为实际公钥）
                                    // 疑问：Reality的原理是什么？
                                    // 回答：服务器伪装成一个真实网站（如mozilla.org），
                                    //       只有持有正确公钥的客户端才能识别出是代理服务器，
                                    //       其他流量（如审查机构的探测）则被转发给真实网站
        }
      },
      "packet_encoding": "xudp"   // UDP包编码：XUDP（X-Ray的UDP优化方案，减少UDP延迟）
    },

    // ▸ 节点 pkpk02：Hysteria2（速度最强的UDP协议）
    // Hysteria2是专为高延迟/高丢包网络设计的协议
    // 核心特性：伪装成HTTP/3流量，内置拥塞控制优化
    {
      "type": "hysteria2",         // 协议：Hysteria2（基于QUIC的高性能代理协议）
      "tag": "pkpk02",             // 节点标签
      "connect_timeout": "5s",     // 连接超时：5秒
      "tcp_fast_open": true,       // TCP快速打开（QUIC本身也有类似机制）
      "tcp_keep_alive": "30s",     // 保活间隔
      "tcp_keep_alive_interval": "5s", // 保活包间隔
      "udp_fragment": true,        // UDP分片
      "server": "节点域名",         // 服务器地址（占位符）
      "server_port": 端口,          // 主端口（占位符）
      "server_ports": "跳跃端口",  // 端口跳跃范围（占位符，如"40000:50000"）
                                    // 疑问：什么是端口跳跃？为什么需要它？
                                    // 回答：Hysteria2可以在指定端口范围内随机切换端口，
                                    //       使QoS/流量整形系统难以精准针对特定端口限速或封锁
      "hop_interval": "30s",       // 跳跃间隔：每30秒切换一个新端口
      "hop_interval_max": "1m0s",  // 最大跳跃间隔：1分钟（随机在30s-60s之间跳跃）
      "up_mbps": 200,              // 上行带宽限制：200 Mbps（告知服务器客户端上行能力）
      "down_mbps": 1000,           // 下行带宽限制：1000 Mbps（告知服务器客户端下行能力）
                                    // 疑问：设置带宽有什么用？
                                    // 回答：Hysteria2使用BBR+Brutal拥塞控制，
                                    //       根据声明的带宽来决定发包速率，合理设置可最大化速度
      "password": "密码",           // 认证密码（占位符）
      "tls": {                     // TLS配置
        "enabled": true,           // 启用TLS
        "server_name": "addons.mozilla.org", // SNI伪装
        "alpn": "h3",              // ALPN协议标识：h3（HTTP/3），伪装成普通HTTP/3流量
        "certificate_public_key_sha256": "密钥" // 证书公钥SHA256指纹（占位符）
                                    // 作用：固定证书指纹，防止中间人攻击（即使CA被妥协也安全）
      },
      "stream_receive_window": 0,  // QUIC流接收窗口：0=使用默认值
      "connection_receive_window": 0  // QUIC连接接收窗口：0=使用默认值
    },

    // ▸ 节点 pkpk03：VLESS + gRPC传输 + Reality
    // gRPC（HTTP/2）传输层，某些网络环境对HTTP/2优化更好
    {
      "type": "vless",             // 协议：VLESS
      "tag": "pkpk03",             // 标签
      "connect_timeout": "5s",
      "tcp_fast_open": true,
      "tcp_keep_alive": "30s",
      "tcp_keep_alive_interval": "5s",
      "udp_fragment": true,
      "server": "节点域名",
      "server_port": 端口,
      "uuid": "uuid",
      // 注意：pkpk03没有flow字段（无XTLS-Vision），因为gRPC传输不兼容XTLS
      "tls": {
        "enabled": true,
        "server_name": "addons.mozilla.org",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"  // 模拟Chrome浏览器指纹
        },
        "reality": {
          "enabled": true,
          "public_key": "密钥"     // Reality公钥（占位符）
        }
      },
      "transport": {               // 传输层配置
        "type": "grpc",            // 传输协议：gRPC（Google开发的RPC框架，基于HTTP/2）
