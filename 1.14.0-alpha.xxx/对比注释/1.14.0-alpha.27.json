  // ══════════════════════════════════════════════
  // 【第八节】experimental —— 实验性功能配置
  // ══════════════════════════════════════════════

  "experimental": {

    // ────────────────────────────────────────────
    // cache_file —— 持久化缓存文件
    // 将DNS缓存和FakeIP映射持久化存储，重启后不需要重新建立缓存
    // ────────────────────────────────────────────

    "cache_file": {
      "enabled": true,             // 启用缓存文件
      "path": "cache.db",          // 缓存文件路径：当前目录下的cache.db（SQLite数据库）
      "cache_id": "cinchov",       // 缓存ID：唯一标识符（不同配置文件用不同ID避免缓存混淆）
      "store_fakeip": true,        // 持久化FakeIP映射：重启后FakeIP域名→IP对应关系不丢失
      "store_dns": true            // 持久化DNS缓存：重启后DNS解析结果不丢失，加快启动速度
    },

    // ────────────────────────────────────────────
    // clash_api —— Clash兼容API
    // 提供与Clash控制器兼容的API接口，使Clash面板（如Yacd、Metacubexd）可以管理sing-box
    // ────────────────────────────────────────────

    "clash_api": {
      "external_controller": "127.0.0.1:9090", // API监听地址：本机9090端口
                                                  // 通过浏览器访问 http://127.0.0.1:9090 管理代理
      "external_ui": "ui",         // 面板目录：相对路径"ui"（存放Yacd/Metacubexd等面板文件）
                                    // 访问 http://127.0.0.1:9090/ui 打开管理界面
      "default_mode": "rule"       // 默认模式：rule（规则模式，即按路由规则分流）
                                    // 其他模式：global（全局代理）、direct（全局直连）
    },

    // ────────────────────────────────────────────
    // debug —— 调试/性能配置
    // ────────────────────────────────────────────

    "debug": {
      "gc_percent": 100,           // Go垃圾回收触发比例：100%（当内存增长到初始量的2倍时触发GC）
                                    // 较低的值=更频繁GC=内存占用低但CPU消耗高
                                    // 100是Go的默认值，平衡内存和CPU
      "memory_limit": "400MB"      // 内存上限：400MB（超过此限制会强制触发GC）
                                    // 疑问：移动设备内存紧张时可以调低此值，如"200MB"
                                    // 回答：适合手机等内存有限的设备，避免被系统杀进程
    }

  } // experimental结束

} // 整个配置文件结束

// ============================================================
// 【附录：整体架构总结】
//
// 流量处理流程（以访问 youtube.com 为例）：
//
// 1. 应用发起连接 → TUN网卡/代理端口接收
// 2. DNS查询 youtube.com：
//    - 匹配dns.rules第3条 → 分配FakeIP（如198.18.1.1）
//    - 应用拿到FakeIP，向198.18.1.1发起TCP连接
// 3. sing-box收到198.18.1.1的流量：
//    - reverse_mapping 还原：198.18.1.1 → youtube.com
//    - 嗅探：识别为HTTPS/TLS流量
// 4. 路由匹配 youtube.com：
//    - 匹配route.rules第9条(domain_suffix) → outbound: PROXY
// 5. 走PROXY选择器 → 默认走"🟢自动-测速" → 选延迟最低的节点
// 6. 通过VLESS/Hysteria2等协议连接代理服务器，访问youtube.com
//
// 国内访问 bilibili.com 的流程：
// 1. DNS查询：匹配dns.rules第8条(cn规则集) → 用dnspub-doh解析 → 返回真实IP
// 2. 流量路由：匹配route.rules第20条(domain_suffix) → outbound: DIRECT
// 3. 直连访问bilibili.com，不经过代理
//
// 广告域名 example-ad.com 的流程：
// 1. DNS查询：匹配dns.rules第11条(Ads规则集) → action:predefined → 返回空（DNS层屏蔽）
// 2. 即使DNS查询绕过，路由规则第24条也会drop流量
// ============================================================
