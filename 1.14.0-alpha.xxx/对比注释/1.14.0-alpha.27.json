          "",
          "",
          "",
          "",
          "",
          "",
          "",
          "-----END CERTIFICATE-----"   // 证书结束标记
        ]
      }
    },

    // ▸ 节点 pkg09：Naive协议（QUIC传输模式）
    // 与pkg08相比，启用了QUIC传输，实现UDP原生支持
    {
      "type": "naive",
      "tag": "pkg09",
      "server": "节点域名",
