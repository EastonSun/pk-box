      "uuid": "uuid",
      "tls": {
        "enabled": true,
        "server_name": "addons.mozilla.org",
        "utls": {
          "enabled": true,
          "fingerprint": "firefox"
        },
        "reality": {
          "enabled": true,
          "public_key": "密钥"
        }
      },
      "transport": {
        "type": "http"             // 传输层：HTTP（将流量伪装成HTTP请求）
      },
      "packet_encoding": "xudp"
    },

    // ▸ 节点 pkg06：VLESS + gRPC传输 + Reality（无多路复用版）
    {
      "type": "vless",
      "tag": "pkg06",
