          "enabled": true,
          "fingerprint": "firefox"
        }
      },
      "password": "密码",
      "idle_session_check_interval": "30s", // 空闲会话检查间隔：每30秒检查一次
      "idle_session_timeout": "30s",        // 会话空闲超时：30秒无活动则关闭
      "min_idle_session": 5                 // 最少保持5个空闲会话（预连接，减少新请求延迟）
    },

    // ▸ 节点 pkg08：Naive协议（HTTP/2传输，TCP模式）
    // NaiveProxy将流量伪装成普通的Chrome用户HTTPS浏览流量
    // 极难被流量分析工具识别，因为它利用了Chrome的真实TLS栈
    {
      "type": "naive",             // 协议：NaiveProxy（基于HTTP/2的隐蔽代理）
      "tag": "pkg08",
      "server": "节点域名",
      "server_port": 端口,
      "username": "name",          // 用户名（占位符）
