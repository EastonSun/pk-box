  // ══════════════════════════════════════════════
  // 【第七节】route —— 路由配置
  // 决定每个网络连接走哪个出站（DIRECT/PROXY/REJECT等）
  // 规则从上到下依次匹配，第一个匹配到的规则生效
  // ══════════════════════════════════════════════

  "route": {
    "rules": [

      // ▸ 路由规则1：流量嗅探（必须放在最前面）
      // 嗅探：检测流量的真实协议和域名（即使数据已加密也能识别）
      // 用于从TUN拦截的原始IP流量中还原出域名信息，使域名规则能正确匹配
      {
        "action": "sniff"          // 动作：嗅探流量（不路由，只是识别协议/域名）
      },

      // ▸ 路由规则2：劫持DNS查询
      // 将所有发往端口53或DNS协议的流量转给sing-box内置DNS处理
      {
        "type": "logical",         // 类型：逻辑组合规则
        "mode": "or",              // 模式：OR（满足任一条件即匹配）
        "rules": [
          { "port": 53 },          // 目标端口53（标准DNS端口）
          { "protocol": "dns" }    // 或者协议识别为DNS
        ],
        "action": "hijack-dns"     // 动作：劫持DNS（转给内置DNS处理，不转发到外部）
      },

      // ▸ 路由规则3：拒绝DoT（DNS over TLS）和mDNS端口
      {
        "port": [
          853,                     // DoT（DNS over TLS）端口：拒绝，强制所有DNS走sing-box处理
          5353                     // mDNS（多播DNS）端口：拒绝外泄
        ],
        "action": "reject"
      },

      // ▸ 路由规则4：Google QUIC流量 → 丢弃（针对特定域名）
      // Google的某些QUIC连接无法被代理正确处理，直接丢弃强制降级到TCP
      {
        "type": "logical",
        "mode": "and",             // AND：同时满足以下所有条件
        "rules": [
          { "protocol": "quic" },  // 条件1：协议为QUIC
          {
            "domain_suffix": [     // 条件2：域名是Google Play相关
              "play.google.com",
              "play.googleapis.com",
              "play-fe.googleapis.com",
              "play-lh.googleusercontent.com",
              "play-apps-features.googleusercontent.com",
              "ggpht.com",
              "googleusercontent.com"
            ]
          }
        ],
        "action": "reject",        // 拒绝
        "method": "drop"           // 方式：静默丢弃（不发送任何拒绝响应）
                                    // 疑问：丢弃后会怎样？
                                    // 回答：QUIC连接失败后，客户端会自动回退到TCP/HTTPS，
                                    //       代理对TCP的支持更完善
      },

      // ▸ 路由规则5：代理域名的QUIC流量 → QUIC专用节点组
      // 对需要代理的域名，如果使用了QUIC协议，走专门支持UDP的节点
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          { "protocol": "quic" },  // 条件1：协议是QUIC
          {
            "type": "logical",
            "mode": "or",          // 条件2：OR（满足以下任一域名/规则集）
            "rules": [
              {
                "rule_set": [      // 通过规则集匹配需要代理的域名
                  "geosite-google", "geosite-youtube", "instagram", "telegram",
                  "Google", "Proxy", "gfw", "ai", "games", "GlobalMedia", "proxy"
                ]
              },
              {
                "domain_suffix": [ // 或者匹配以下具体域名后缀
                  "play.google.com", "play.googleapis.com", "play-fe.googleapis.com",
                  "play-lh.googleusercontent.com", "android.clients.google.com",
                  "android.googleapis.com", "dl.google.com", "dl.l.google.com",
                  "gvt1.com", "gvt2.com", "gvt3.com", "ggpht.com", "googleusercontent.com",
                  "twitter.com", "twimg.com", "facebook.com", "fbcdn.net",
                  "netflix.com", "spotify.com", "github.com", "steampowered.com",
                  "discord.com", "reddit.com", "tiktok.com", "amazon.com", "paypal.com"
                ]
              }
            ]
          }
        ],
        "outbound": "🟣 QUIC-UDP"  // 出站：走QUIC专用节点组
      },

      // ▸ 路由规则6：Google消息推送服务（FCM）→ PROXY
      // mtalk.google.com及其备用服务器处理Android设备推送通知
      // 必须走代理才能在国内收到Google FCM推送
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "domain_suffix": [
              "mtalk.google.com",           // Google推送主服务器
              "alt1-mtalk.google.com",      // 备用推送服务器1
              "alt2-mtalk.google.com",      // 备用推送服务器2
              "alt3-mtalk.google.com",      // 备用推送服务器3
              "alt4-mtalk.google.com",      // 备用推送服务器4
              "alt5-mtalk.google.com",      // 备用推送服务器5
              "alt6-mtalk.google.com",      // 备用推送服务器6
              "alt7-mtalk.google.com",      // 备用推送服务器7
              "alt8-mtalk.google.com"       // 备用推送服务器8
            ]
          },
          {
            "port": [443, 5228]    // 端口：443（HTTPS）或5228（FCM专用端口）
          }
        ],
        "outbound": "PROXY"
      },

      // ▸ 路由规则7：正则匹配特定Google/Telegram应用 → PROXY
      // 使用正则表达式匹配包名，精确控制特定应用走代理
      {
        "package_name_regex": "^(com\\.google\\.android\\.(youtube|apps\\.(maps|docs|drive|photos))|app\\.revanced\\.android\\.youtube|org\\.telegram\\.messenger(\\..*)?)$",
        // 解析：匹配以下包名（Android应用包名）：
        // - com.google.android.youtube：YouTube官方
        // - com.google.android.apps.maps：Google地图
        // - com.google.android.apps.docs：Google文档
        // - com.google.android.apps.drive：Google Drive
        // - com.google.android.apps.photos：Google相册
        // - app.revanced.android.youtube：YouTube ReVanced（去广告修改版）
        // - org.telegram.messenger（及其子包）：Telegram所有版本
        "outbound": "PROXY"
      },

      // ▸ 路由规则8：IP检测/隐私检测网站 → PROXY
      // 这些网站用于检测真实IP、DNS泄漏等，必须走代理以获取代理出口IP
      {
        "domain_suffix": [
          "browserleaks.com",      // 浏览器信息泄漏检测
          "ipleak.net",            // IP泄漏检测
          "dnsleaktest.com",       // DNS泄漏测试
          "whoer.net",             // 代理/VPN检测
          "whatleaks.com",         // 各类泄漏检测
          "ip.sb",                 // IP查询
          "ipinfo.io",             // IP地理位置查询
          "ifconfig.me",           // 显示出口IP（类似ifconfig命令）
          "ip-api.com"             // IP地理信息API
        ],
        "outbound": "PROXY"        // 必须走代理，否则会显示真实IP
      },

      // ▸ 路由规则9：Google全系服务 → PROXY
      {
        "domain_suffix": [
          "play.google.com", "play.googleapis.com",
          "android.clients.google.com", "android.googleapis.com",
          "dl.google.com", "dl.l.google.com",
          "gvt1.com", "gvt2.com", "gvt3.com",
          "services.googleapis.com", "googleapis.com",
          "gstatic.com", "ggpht.com", "googleusercontent.com",
          "google.com", "google.com.hk",
          "youtube.com", "ytimg.com", "googlevideo.com",
          "app-measurement.com",
          "firebaselogging.googleapis.com",
          "firebaselogging-pa.googleapis.com"
        ],
        "outbound": "PROXY"
      },

      // ▸ 路由规则10：规则集匹配的代理域名 → PROXY
      {
        "rule_set": [
          "geosite-google",        // Google域名集
          "geosite-youtube",       // YouTube域名集
          "instagram",             // Instagram域名集
          "telegram",              // Telegram域名集
          "telegram_ip",           // Telegram IP段（某些Telegram服务器直接用IP）
          "Google",                // Google扩展域名集
          "fcm",                   // Firebase Cloud Messaging（推送服务）域名集
          "Android"                // Android系统服务域名集
        ],
        "outbound": "PROXY"
      },

      // ▸ 路由规则11：主流境外服务 → PROXY
      {
        "domain_suffix": [
          "netflix.com",           // Netflix流媒体
          "spotify.com",           // Spotify音乐
          "github.com",            // GitHub代码托管
          "steampowered.com",      // Steam游戏平台
          "discord.com",           // Discord通讯
          "reddit.com",            // Reddit社区
          "tiktok.com",            // TikTok（海外版抖音）
          "twitter.com",           // Twitter/X
          "twimg.com",             // Twitter CDN
          "facebook.com",          // Facebook
          "fbcdn.net",             // Facebook CDN
          "amazon.com",            // Amazon购物/AWS
          "microsoft.com",         // 微软（全球版）
          "paypal.com"             // PayPal支付
        ],
        "outbound": "PROXY"
      },

      // ▸ 路由规则12：规则集批量代理域名 → PROXY
      {
        "rule_set": [
          "Proxy",                 // 通用代理域名集（非中国大陆域名）
          "gfw",                   // GFW封锁域名集
          "ai",                    // AI服务域名集（ChatGPT/Claude/Gemini等）
          "games",                 // 境外游戏平台域名集
          "GlobalMedia",           // 全球流媒体域名集
          "proxy"                  // 另一个代理域名集（小写proxy）
        ],
        "outbound": "PROXY"
      },

      // ▸ 路由规则13：Clash Global模式 → PROXY
      // 当用户在面板中切换到"Global"模式时，所有流量走代理
      {
        "clash_mode": "Global",    // 匹配Clash API的模式
        "outbound": "PROXY"
      },

      // ▸ 路由规则14：FakeIP地址段 → PROXY
      // 198.18.0.0/15是FakeIP地址池，收到这些目标IP的流量必须走代理
      // （sing-box会通过reverse_mapping找到真实域名再建立代理连接）
      {
        "ip_cidr": "198.18.0.0/15", // FakeIP的IPv4地址段
        "outbound": "PROXY"
      },

      // ▸ 路由规则15：FakeIP IPv6地址段 → PROXY
      {
        "ip_cidr": "fc00::/18",    // FakeIP的IPv6地址段
        "outbound": "PROXY"
      },

      // ▸ 路由规则16：第二次嗅探（疑问：为什么要嗅探两次？）
      // 回答：第一次sniff（规则1）在路由判断之前执行，识别协议类型；
      //       第二次sniff（规则16）在前面的规则都不匹配后再次执行，
      //       确保后续直连/国内规则也能拿到准确的协议信息
      {
        "action": "sniff"          // 再次嗅探流量协议
      },

      // ▸ 路由规则17：NTP和ICMP协议 → DIRECT
      {
        "protocol": [
          "ntp",                   // NTP时间同步协议（直连更准确）
          "icmp"                   // ICMP（ping等网络诊断工具使用）
        ],
        "outbound": "DIRECT"
      },

      // ▸ 路由规则18：私有IP → DIRECT
      // 内网设备通信不走代理
      {
        "ip_is_private": true,     // 匹配所有私有IP地址（10.x.x.x、192.168.x.x、172.16-31.x.x等）
        "outbound": "DIRECT"
      },

      // ▸ 路由规则19：规则集批量直连域名 → DIRECT
      {
        "rule_set": [
          "private",               // 私有网络域名
          "cn",                    // 中国大陆域名集
          "cnip",                  // 中国大陆IP集
          "microsoft-cn",          // 微软中国版服务（如Bing中文、Office中国区）
          "apple-cn",              // 苹果中国版服务（Apple中国区App Store等）
          "games-cn",              // 国内游戏平台（网易游戏、腾讯游戏等）
          "networktest"            // 网络测试域名（如speedtest等，用直连测真实速度）
        ],
        "outbound": "DIRECT"
      },

      // ▸ 路由规则20：国内主流应用域名 → DIRECT
      // 手动列举确保这些服务直连访问（部分在规则集中已包含，此处作为补充）
      {
        "domain_suffix": [
          "alipay.com",            // 支付宝
          "alipayobjects.com",     // 支付宝静态资源
          "alicdn.com",            // 阿里CDN
          "aliyuncs.com",          // 阿里云计算资源
          "qcloud.com",            // 腾讯云
          "cloud.tencent.com",     // 腾讯云官网
          "mi.com",                // 小米
          "xiaomi.com",            // 小米（国际域名）
          "huawei.com",            // 华为
          "vivo.com.cn",           // vivo手机
          "oppo.com",              // OPPO手机
          "coolapk.com",           // 酷安应用市场
          "wps.cn",                // WPS办公
          "biliapi.com",           // Bilibili API
          "api.bilibili.com",      // Bilibili API（子域名形式）
          "www.bilibili.com",      // Bilibili主站
          "bilivideo.com",         // Bilibili视频CDN
          "hdslb.com",             // Bilibili高清视频CDN
          "bilicdn1.com",          // Bilibili CDN1
          "bilicdn.com",           // Bilibili CDN
          "xiaohongshu.com",       // 小红书
          "xhscdn.com",            // 小红书CDN
          "kuaishou.com",          // 快手
          "ixigua.com",            // 西瓜视频（字节跳动）
          "sponsor.ajay.app",      // SponsorBlock（YouTube跳过广告插件的API）
          "ifbapp.com",            // 国内某应用
          "allawnos.com",          // 国内某CDN/应用服务
          "heytapmobi.com",        // OPPO/一加应用商店
          "steamserver.net"        // Steam服务器（部分走直连，与CDN分开）
        ],
        "outbound": "DIRECT"
      },

      // ▸ 路由规则21：国内主流应用包名 → DIRECT
      // 通过Android应用包名精确匹配，确保这些应用直连
      {
        "package_name": [
          "com.tencent.mm",                // 微信
          "com.eg.android.AlipayGphone",   // 支付宝
          "com.netease.cloudmusic",         // 网易云音乐
          "com.wwwscn.yuexingbao"           // 悦行宝（某国内应用）
        ],
        "outbound": "DIRECT"
      },

      // ▸ 路由规则22：Clash Direct模式 → DIRECT
      // 用户在面板切换到"Direct"模式时，所有流量直连
      {
        "clash_mode": "Direct",    // 匹配Clash API的Direct模式
        "outbound": "DIRECT"
      },

      // ▸ 路由规则23：Google中国版域名 → DIRECT
      // 疑问：google.cn可以直连吗？
      // 回答：google.cn在中国大陆可以访问（谷歌为此保留的中国版域名），
      //       走直连比走代理更快
      {
        "domain_suffix": [
          "google.cn",             // Google中国版
          "googleapis.cn"          // Google API中国版
        ],
        "outbound": "DIRECT"
      },

      // ▸ 路由规则24：广告/DNS污染规则集 → 丢弃
      {
        "rule_set": [
          "Ads",                   // 广告域名集
          "httpDNS",               // 绕过系统DNS的HTTP DNS请求
          "DNSreject",             // 需要DNS拒绝的域名
          "geosite_adguard",       // AdGuard广告过滤
          "geosite-category-ads-all" // 所有广告分类域名
        ],
        "action": "reject",        // 拒绝
        "method": "drop"           // 静默丢弃
      },

      // ▸ 路由规则25：特定追踪/广告域名 → 丢弃
      {
        "domain": [                // 精确匹配完整域名（非后缀匹配）
          "beacon.qq.com",         // QQ统计信标
          "abyss.cyapi.cn",        // 彩云天气API追踪
          "ad.cyapi.cn",           // 彩云天气广告API
          "gather.colorfulclouds.net" // 彩云天气数据收集
        ],
        "action": "reject",
        "method": "drop"
      },

      // ▸ 路由规则26：反诈骗规则集 → 拒绝（不丢弃，返回响应）
      {
        "rule_set": "anti_fraud",  // 诈骗/钓鱼网站域名集
        "action": "reject"         // 拒绝（注意：不是drop，会返回拒绝响应，告知用户被屏蔽）
      },

      // ▸ 路由规则27：拦截STUN和DTLS协议
      // STUN用于WebRTC实时通信，可能泄漏真实IP（WebRTC泄漏）
      // DTLS是基于UDP的TLS，WebRTC使用它加密媒体流
      {
        "protocol": [
          "stun",                  // STUN（Session Traversal Utilities for NAT）
                                    // 用于WebRTC的NAT穿越，可能绕过代理暴露真实IP
          "dtls"                   // DTLS（Datagram TLS）WebRTC媒体流加密协议
        ],
        "action": "reject"         // 拒绝：阻止WebRTC IP泄漏
      },

      // ▸ 路由规则28：路由选项配置
      {
        "action": "route-options",       // 动作：设置路由选项（不影响流量走向，只改变行为参数）
        "udp_disable_domain_unmapping": true, // 禁用UDP域名反映射
                                              // 疑问：这是什么意思？
                                              // 回答：正常情况下FakeIP会被反映射回域名，
                                              //       此选项禁止某些UDP场景下的这种行为，
                                              //       避免UDP流量处理异常
        "udp_connect": true              // 启用UDP connect模式：UDP流量也建立"连接"状态，
                                          // 使UDP处理更像TCP，改善某些应用的兼容性
      },

      // ▸ 路由规则29：强制DNS解析
      // 所有到达此规则的流量（主要是直连流量），先做DNS解析获取真实IP
      {
        "action": "resolve"        // 动作：解析域名为IP地址
                                    // 放在最后确保直连流量有真实IP可用
      }

    ], // route.rules结束

